# ============================================================
# Webshop-CRM — environment template
# Kopieer naar .env en vul echte waardes in.
# .env staat in .gitignore en mag NOOIT gecommit worden.
# ============================================================

# ─── Node / Runtime ───────────────────────────────────────────
NODE_ENV=development

# ─── Database (Postgres 16) ───────────────────────────────────
# Lokale dev draait via docker-compose.dev.yml
DATABASE_URL=postgres://webshop:webshop@localhost:5432/webshop_crm
# Optioneel: aparte test-DB
TEST_DATABASE_URL=postgres://webshop:webshop@localhost:5432/webshop_crm_test

# ─── Redis (BullMQ) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API server ───────────────────────────────────────────────
API_PORT=7300
API_HOST=127.0.0.1
API_PUBLIC_URL=http://localhost:7300

# ─── Admin frontend ───────────────────────────────────────────
ADMIN_PORT=7301
ADMIN_PUBLIC_URL=http://localhost:7301

# ─── Auth secrets ─────────────────────────────────────────────
# 32+ char random; gegenereerd via `openssl rand -hex 32`
SESSION_SECRET=change-me-32-bytes-of-random-hex-please-actually-change-me
# Encryption-key voor channel-credentials in DB (pgcrypto)
CHANNEL_SECRET_KEY=change-me-32-bytes-of-random-hex-for-pgcrypto-aes
# Lengte van sessie-cookie (dagen)
SESSION_TTL_DAYS=30

# ─── Eerste admin-user (seed-script) ──────────────────────────
SEED_ADMIN_EMAIL=admin@webshop-crm.local
SEED_ADMIN_PASSWORD=change-me-please

# ─── Storage (V1 = local FS) ──────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# V2: STORAGE_DRIVER=s3 + S3_BUCKET, S3_REGION, etc.

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Feature flags ────────────────────────────────────────────
# Zet op true om dev-only routes (/api/dev/*) aan te zetten
ENABLE_DEV_ROUTES=true

# ============================================================
# PLACEHOLDERS voor latere fasen — niet gebruikt in Fase 1
# ============================================================

# Fase 2 — storefront-API tokens (per shop een token)
# STOREFRONT_TOKEN_SHOP1=

# Fase 3 — Bol/Amazon/GMC channel credentials worden in DB
# bewaard (encrypted via CHANNEL_SECRET_KEY). Geen env nodig.

# Fase 4 — Moneybird OAuth
# MONEYBIRD_CLIENT_ID=
# MONEYBIRD_CLIENT_SECRET=
# MONEYBIRD_REDIRECT_URI=http://localhost:7300/api/accounting/moneybird/callback

# Fase 5 — Sendcloud / MyParcel
# SENDCLOUD_PUBLIC_KEY=
# SENDCLOUD_SECRET_KEY=

# Cloudflared tunnels (named) — Fase 1 ondersteunend
# CLOUDFLARE_TUNNEL_API=api.example.com
# CLOUDFLARE_TUNNEL_ADMIN=admin.example.com
