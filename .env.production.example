# ============================================================
# Webshop-CRM — PRODUCTIE environment template
#
#   1. cp .env.production.example .env.production
#   2. vul de waardes hieronder in (zie de TODO-regels)
#   3. docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
# .env.production bevat ECHTE secrets en staat in .gitignore — nooit committen.
# ============================================================

# ─── Publieke URL van de CRM ──────────────────────────────────
# Het adres waarop je de admin straks opent. Gebruikt voor CORS,
# feed-links en publieke storefront-URLs.
#   met domein + TLS:   https://crm.jouwdomein.nl
#   lokaal testen:       http://localhost
PUBLIC_URL=https://crm.jouwdomein.nl

# Adres waarop Caddy luistert (auto-HTTPS bij een echt https-domein).
#   productie:  https://crm.jouwdomein.nl
#   lokaal:     :80
SITE_ADDRESS=https://crm.jouwdomein.nl

# Optioneel: publieke API-base die in het "Koppel je webshop"-snippet
# getoond wordt (Shops → connect). Meestal PUBLIC_URL + /api
PUBLIC_API_URL=https://crm.jouwdomein.nl/api

# Optioneel: poorten op de host (default 80/443).
# HTTP_PORT=80
# HTTPS_PORT=443

# ─── Database (Postgres-container) ────────────────────────────
POSTGRES_USER=webshop
# ⚠️ BELANGRIJK — wachtwoord-vorm:
#   Het DB-wachtwoord gaat RAUW in de DATABASE_URL (compose interpoleert het in
#   postgres://user:PASSWORD@postgres:5432/db). Tekens als  @ : / # ? %  en
#   spaties BREKEN die connection-string. Gebruik daarom een wachtwoord ZONDER
#   speciale tekens. Genereer een veilig hex-wachtwoord met:
#       openssl rand -hex 24
#   (48 hex-tekens, alleen [0-9a-f] → altijd URL-veilig, geen encoding nodig).
# TODO: vervang met de output van `openssl rand -hex 24`.
POSTGRES_PASSWORD=CHANGE_ME_run_openssl_rand_hex_24
POSTGRES_DB=webshop_crm
# DATABASE_URL hoeft hier NIET gezet te worden — compose stelt 'm samen
# uit bovenstaande POSTGRES_* en wijst naar de interne db-service.

# ─── Auth secrets (VERPLICHT, min. 32 tekens) ─────────────────
# Genereer elk met:  openssl rand -hex 32
# TODO: vervang beide.
SESSION_SECRET=CHANGE_ME_32_bytes_random_hex_voor_sessies______
CHANNEL_SECRET_KEY=CHANGE_ME_32_bytes_random_hex_voor_channel_creds_
SESSION_TTL_DAYS=30

# ─── Eerste admin-login (seed, idempotent) ────────────────────
SEED_ADMIN_EMAIL=admin@jouwdomein.nl
# TODO: kies je admin-wachtwoord (min. 8 tekens).
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_wachtwoord

# ─── Sessie-cookie Secure-flag (ontkoppeld van NODE_ENV) ──────
# Standaard (leeg laten): de cookie krijgt `Secure` zodra PUBLIC_URL https is.
#   - Domein + auto-HTTPS via Caddy   → leeg laten (https-URL ⇒ Secure aan).
#   - Lokaal/IP-test over plain http  → COOKIE_SECURE=false  (anders weigert de
#       browser de cookie en lukt inloggen niet).
#   - Achter Cloudflare-tunnel / externe TLS-proxy (Caddy intern :80, extern
#       https) → COOKIE_SECURE=true  én zorg dat de proxy X-Forwarded-Proto=https
#       doorzet. PUBLIC_URL is dan je externe https-adres.
# COOKIE_SECURE=

# ─── Overig (defaults zijn prima) ─────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# Achtergrond-sync voor gekoppelde kanalen (Bol/Amazon). Pas actief
# zodra je kanaal-credentials invult in de admin.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=900000

# ============================================================
# Externe koppelingen (Bol/Amazon/Mollie/boekhouding/verzending)
# worden NIET hier gezet — die vul je in de admin in (encrypted in de DB).
# Zie docs/CONNECT-OFFICIAL.md en docs/DEPLOY.md (sectie "Koppelingen").
# ============================================================
