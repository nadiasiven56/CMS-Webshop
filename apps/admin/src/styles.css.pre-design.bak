@tailwind base;
@tailwind components;
@tailwind utilities;

/* ============================================================
   AI Centrum theme — operator's house theme
   Geport uit: shared/from-agent1/AI-CENTRUM/frontend/src/styles.css
   Anatomy: zie reference_hermes_theme_anatomy.md
   ============================================================ */

:root,
[data-theme='ai-centrum'] {
  /* Surfaces */
  --theme-bg: #0d0f12;
  --theme-sidebar: #15181d;
  --theme-panel: #15181d;
  --theme-card: #1b1f26;
  --theme-card2: #101216;
  --theme-border: rgba(238, 242, 248, 0.11);
  --theme-border-subtle: rgba(238, 242, 248, 0.08);

  /* Text */
  --theme-text: #f4f6f8;
  --theme-muted: #9aa1ad;

  /* Shadows */
  --theme-shadow-1: 0 1px 2px rgba(0, 0, 0, 0.55);
  --theme-shadow-2: 0 6px 16px rgba(0, 0, 0, 0.48);
  --theme-shadow-3: 0 16px 36px rgba(0, 0, 0, 0.58);
  --theme-glass: rgba(13, 15, 18, 0.88);

  /* Accent (warm orange) */
  --theme-focus: #ff9f43;
  --theme-accent: #ff9f43;
  --theme-accent-secondary: #ff7a2f;
  --theme-accent-subtle: rgba(255, 159, 67, 0.12);
  --theme-accent-border: rgba(255, 159, 67, 0.34);

  /* Status */
  --theme-active: #ff9f43;
  --theme-link: #ff9f43;
  --theme-success: #4ade80;
  --theme-warning: #ff9f43;
  --theme-danger: #ff6b57;

  /* Forms */
  --theme-input: #15181d;
  --theme-stripe: rgba(238, 242, 248, 0.04);
  --theme-header-bg: #0d0f12;
  --theme-header-border: rgba(238, 242, 248, 0.11);

  color-scheme: dark;
}

html,
body,
#root {
  background-color: var(--theme-bg);
  color: var(--theme-text);
  min-height: 100vh;
}

body {
  font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
  font-size: 14px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

/* Form-controls follow theme */
input,
textarea,
select {
  background-color: var(--theme-input);
  color: var(--theme-text);
  border: 1px solid var(--theme-border);
  border-radius: 8px;
  padding: 0.55rem 0.75rem;
  font: inherit;
  transition: border-color 120ms ease, box-shadow 120ms ease;
  outline: none;
}

input:focus,
textarea:focus,
select:focus {
  border-color: var(--theme-accent-border);
  box-shadow: 0 0 0 3px var(--theme-accent-subtle);
}

button {
  font: inherit;
  cursor: pointer;
}

/* ─── Layout primitives ─────────────────────────────────────── */
.app-shell {
  display: grid;
  grid-template-columns: 240px 1fr;
  min-height: 100vh;
}

.app-sidebar {
  background: var(--theme-sidebar);
  border-right: 1px solid var(--theme-border);
  padding: 16px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.app-main {
  padding: 28px 32px;
  background: var(--theme-bg);
  min-height: 100vh;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  color: var(--theme-muted);
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  transition: background 120ms ease, color 120ms ease;
}

.nav-link:hover {
  background: var(--theme-card2);
  color: var(--theme-text);
}

.nav-link[data-active='true'] {
  background: var(--theme-accent-subtle);
  color: var(--theme-accent);
  border: 1px solid var(--theme-accent-border);
}

/* ─── Card primitives ───────────────────────────────────────── */
.card {
  background: var(--theme-card);
  border: 1px solid var(--theme-border);
  border-radius: 12px;
  padding: 20px;
  box-shadow: var(--theme-shadow-1);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.card-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--theme-text);
  margin: 0;
}

.card-subtitle {
  color: var(--theme-muted);
  font-size: 13px;
  margin-top: 4px;
}

/* ─── Buttons ───────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 16px;
  border-radius: 8px;
  border: 1px solid transparent;
  font-weight: 500;
  font-size: 14px;
  transition: background 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  white-space: nowrap;
}

.btn-primary {
  background: var(--theme-accent);
  color: #170f07;
  border-color: var(--theme-accent);
}

.btn-primary:hover {
  background: var(--theme-accent-secondary);
}

.btn-primary:active {
  transform: translateY(1px);
}

.btn-secondary {
  background: var(--theme-card2);
  color: var(--theme-text);
  border-color: var(--theme-border);
}

.btn-secondary:hover {
  background: var(--theme-card);
  border-color: var(--theme-accent-border);
}

.btn-ghost {
  background: transparent;
  color: var(--theme-muted);
  border-color: transparent;
}

.btn-ghost:hover {
  background: var(--theme-card2);
  color: var(--theme-text);
}

.btn-danger {
  background: transparent;
  color: var(--theme-danger);
  border-color: var(--theme-danger);
}

.btn-danger:hover {
  background: rgba(255, 107, 87, 0.1);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* ─── Login screen ──────────────────────────────────────────── */
.login-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
  background:
    radial-gradient(ellipse at top, rgba(255, 159, 67, 0.08), transparent 50%),
    var(--theme-bg);
}

.login-card {
  width: 100%;
  max-width: 380px;
  background: var(--theme-card);
  border: 1px solid var(--theme-border);
  border-radius: 16px;
  padding: 32px;
  box-shadow: var(--theme-shadow-3);
}

.login-card h1 {
  font-size: 22px;
  font-weight: 700;
  margin: 0 0 4px;
  color: var(--theme-text);
}

.login-card p.subtitle {
  font-size: 13px;
  color: var(--theme-muted);
  margin: 0 0 24px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}

.field label {
  font-size: 12px;
  font-weight: 500;
  color: var(--theme-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.error-text {
  color: var(--theme-danger);
  font-size: 13px;
  margin-top: 8px;
  margin-bottom: 0;
}

/* ─── Brand mark in sidebar ────────────────────────────────── */
.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px 16px;
  border-bottom: 1px solid var(--theme-border-subtle);
  margin-bottom: 12px;
}

.brand-mark {
  width: 28px;
  height: 28px;
  border-radius: 7px;
  background: var(--theme-accent);
  display: grid;
  place-items: center;
  color: #170f07;
  font-weight: 800;
  font-size: 14px;
}

.brand-name {
  font-weight: 700;
  color: var(--theme-text);
  letter-spacing: -0.01em;
}

/* ─── Tag pill (statuses, badges) ──────────────────────────── */
.pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 500;
  border: 1px solid var(--theme-border);
  background: var(--theme-card2);
  color: var(--theme-muted);
}

.pill-accent {
  background: var(--theme-accent-subtle);
  color: var(--theme-accent);
  border-color: var(--theme-accent-border);
}

/* ─── Empty-state placeholder pages ────────────────────────── */
.empty-state {
  background: var(--theme-card);
  border: 1px dashed var(--theme-border);
  border-radius: 12px;
  padding: 48px 32px;
  text-align: center;
  color: var(--theme-muted);
}

.empty-state h2 {
  color: var(--theme-text);
  font-size: 18px;
  font-weight: 600;
  margin: 0 0 8px;
}

/* ─── Utility ──────────────────────────────────────────────── */
.row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.muted {
  color: var(--theme-muted);
}

/* ─── Mobile collapse ──────────────────────────────────────── */
@media (max-width: 720px) {
  .app-shell {
    grid-template-columns: 1fr;
  }
  .app-sidebar {
    border-right: none;
    border-bottom: 1px solid var(--theme-border);
    flex-direction: row;
    overflow-x: auto;
    padding: 8px;
  }
  .nav-link {
    flex: 0 0 auto;
  }
  .app-main {
    padding: 16px;
  }
}
