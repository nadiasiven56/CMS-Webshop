import { Link } from '@tanstack/react-router';
import { Package } from 'lucide-react';
import { StatusBadge } from './StatusBadge';
import type { ProductListItem } from './types';

interface Props {
  items: ProductListItem[];
  loading?: boolean;
}

function formatRelative(iso: string): string {
  try {
    const d = new Date(iso);
    return new Intl.DateTimeFormat('nl-NL', {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit',
    }).format(d);
  } catch {
    return iso;
  }
}

export function ProductTable({ items, loading }: Props) {
  if (loading) {
    return (
      <div className="card" style={{ textAlign: 'center', padding: 32 }}>
        <span className="muted">Laden…</span>
      </div>
    );
  }
  if (items.length === 0) {
    return (
      <div className="empty-state">
        <h2>Geen producten</h2>
        <p>Klik rechtsboven op "Nieuw product" om er één toe te voegen.</p>
      </div>
    );
  }

  return (
    <div className="card" style={{ padding: 0, overflow: 'hidden' }}>
      <table style={{ width: '100%', borderCollapse: 'collapse' }}>
        <thead>
          <tr style={{ background: 'var(--theme-card2)' }}>
            <Th>Product</Th>
            <Th>Vendor</Th>
            <Th>Type</Th>
            <Th>Status</Th>
            <Th align="right">Varianten</Th>
            <Th>Bijgewerkt</Th>
          </tr>
        </thead>
        <tbody>
          {items.map((p) => (
            <tr
              key={p.id}
              style={{
                borderTop: '1px solid var(--theme-border-subtle)',
              }}
            >
              <Td>
                <Link
                  to="/products/$id"
                  params={{ id: p.id }}
                  style={{
                    display: 'flex',
                    alignItems: 'center',
                    gap: 12,
                    color: 'var(--theme-text)',
                    textDecoration: 'none',
                  }}
                >
                  <Thumbnail url={p.primaryImageUrl} />
                  <div style={{ display: 'flex', flexDirection: 'column' }}>
                    <strong style={{ fontWeight: 600 }}>{p.title}</strong>
                    <span className="muted" style={{ fontSize: 12 }}>
                      /{p.slug}
                    </span>
                  </div>
                </Link>
              </Td>
              <Td>{p.vendor || <span className="muted">—</span>}</Td>
              <Td>{p.productType || <span className="muted">—</span>}</Td>
              <Td>
                <StatusBadge status={p.status} />
              </Td>
              <Td align="right">
                <span className="pill">{p.variantCount}</span>
              </Td>
              <Td>
                <span className="muted" style={{ fontSize: 12 }}>
                  {formatRelative(p.updatedAt)}
                </span>
              </Td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}

function Th({ children, align }: { children: React.ReactNode; align?: 'left' | 'right' }) {
  return (
    <th
      style={{
        textAlign: align ?? 'left',
        padding: '10px 16px',
        fontSize: 12,
        fontWeight: 600,
        textTransform: 'uppercase',
        letterSpacing: '0.04em',
        color: 'var(--theme-muted)',
      }}
    >
      {children}
    </th>
  );
}

function Td({ children, align }: { children: React.ReactNode; align?: 'left' | 'right' }) {
  return (
    <td style={{ padding: '12px 16px', textAlign: align ?? 'left', verticalAlign: 'middle' }}>
      {children}
    </td>
  );
}

function Thumbnail({ url }: { url: string | null }) {
  if (!url) {
    return (
      <div
        style={{
          width: 40,
          height: 40,
          borderRadius: 8,
          background: 'var(--theme-card2)',
          border: '1px solid var(--theme-border)',
          display: 'grid',
          placeItems: 'center',
          color: 'var(--theme-muted)',
        }}
      >
        <Package size={18} />
      </div>
    );
  }
  return (
    <img
      src={url}
      alt=""
      style={{
        width: 40,
        height: 40,
        borderRadius: 8,
        objectFit: 'cover',
        border: '1px solid var(--theme-border)',
      }}
    />
  );
}
