import { Link } from '@tanstack/react-router';
import { AlertTriangle } from 'lucide-react';

export interface StockTableRow {
  itemId: string;
  sku: string;
  productTitle: string | null;
  productId: string | null;
  variantSku: string | null;
  onHandTotal: number;
  availableTotal: number;
  committedTotal: number;
  incomingTotal: number;
  locationsCount: number;
  lowStock: boolean;
}

interface Props {
  rows: StockTableRow[];
  loading?: boolean;
  emptyMessage?: string;
}

export function StockTable({ rows, loading, emptyMessage }: Props) {
  if (loading) {
    return (
      <div className="empty-state" style={{ padding: 24 }}>
        <p className="muted">Laden…</p>
      </div>
    );
  }
  if (rows.length === 0) {
    return (
      <div className="empty-state" style={{ padding: 24 }}>
        <p className="muted">{emptyMessage ?? 'Geen voorraad-items gevonden.'}</p>
      </div>
    );
  }

  return (
    <div
      className="card"
      style={{
        padding: 0,
        overflow: 'hidden',
      }}
    >
      <table
        style={{
          width: '100%',
          borderCollapse: 'collapse',
          fontSize: 14,
        }}
      >
        <thead>
          <tr style={{ background: 'var(--theme-card2, rgba(255,255,255,0.02))' }}>
            <Th>SKU</Th>
            <Th>Product</Th>
            <Th align="right">On hand</Th>
            <Th align="right">Available</Th>
            <Th align="right">Committed</Th>
            <Th align="right">Locations</Th>
            <Th align="center">Status</Th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr
              key={row.itemId}
              style={{
                borderTop: '1px solid var(--theme-border, rgba(255,255,255,0.06))',
              }}
            >
              <Td>
                <Link
                  to="/stock/$itemId"
                  params={{ itemId: row.itemId }}
                  style={{
                    color: 'var(--theme-accent, #ff9f43)',
                    textDecoration: 'none',
                    fontWeight: 600,
                  }}
                >
                  {row.sku}
                </Link>
              </Td>
              <Td>
                <div style={{ color: 'var(--theme-text)' }}>
                  {row.productTitle ?? <span className="muted">—</span>}
                </div>
                {row.variantSku && row.variantSku !== row.sku && (
                  <div className="muted" style={{ fontSize: 12, marginTop: 2 }}>
                    variant: {row.variantSku}
                  </div>
                )}
              </Td>
              <Td align="right">{row.onHandTotal}</Td>
              <Td align="right">
                <strong style={{ color: row.availableTotal <= 0 ? '#ef4444' : 'inherit' }}>
                  {row.availableTotal}
                </strong>
              </Td>
              <Td align="right">{row.committedTotal}</Td>
              <Td align="right">{row.locationsCount}</Td>
              <Td align="center">
                {row.lowStock ? (
                  <span
                    title="Eén of meer locations onder min-stock"
                    style={{
                      display: 'inline-flex',
                      alignItems: 'center',
                      gap: 4,
                      color: '#fbbf24',
                      fontSize: 12,
                    }}
                  >
                    <AlertTriangle size={14} />
                    Low
                  </span>
                ) : (
                  <span className="muted" style={{ fontSize: 12 }}>
                    OK
                  </span>
                )}
              </Td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}

function Th({
  children,
  align,
}: {
  children: React.ReactNode;
  align?: 'left' | 'right' | 'center';
}) {
  return (
    <th
      style={{
        textAlign: align ?? 'left',
        padding: '10px 14px',
        fontWeight: 600,
        fontSize: 12,
        textTransform: 'uppercase',
        color: 'var(--theme-muted)',
        letterSpacing: 0.4,
      }}
    >
      {children}
    </th>
  );
}

function Td({
  children,
  align,
}: {
  children: React.ReactNode;
  align?: 'left' | 'right' | 'center';
}) {
  return (
    <td
      style={{
        textAlign: align ?? 'left',
        padding: '10px 14px',
        verticalAlign: 'top',
      }}
    >
      {children}
    </td>
  );
}
