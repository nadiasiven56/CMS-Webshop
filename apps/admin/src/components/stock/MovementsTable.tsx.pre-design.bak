export interface MovementRow {
  id: string;
  itemId: string;
  itemSku: string | null;
  location: {
    id: string | null;
    code: string | null;
    name: string | null;
  };
  delta: number;
  reason: string;
  refType: string | null;
  refId: string | null;
  actor: { id: string; email: string | null } | null;
  note: string | null;
  createdAt: string | Date;
}

interface Props {
  rows: MovementRow[];
  loading?: boolean;
  showItem?: boolean;
  emptyMessage?: string;
}

export function MovementsTable({ rows, loading, showItem = true, emptyMessage }: Props) {
  if (loading) {
    return (
      <div className="empty-state" style={{ padding: 24 }}>
        <p className="muted">Laden…</p>
      </div>
    );
  }
  if (rows.length === 0) {
    return (
      <div className="empty-state" style={{ padding: 24 }}>
        <p className="muted">{emptyMessage ?? 'Geen mutaties gevonden.'}</p>
      </div>
    );
  }

  return (
    <div className="card" style={{ padding: 0, overflow: 'hidden' }}>
      <table
        style={{
          width: '100%',
          borderCollapse: 'collapse',
          fontSize: 14,
        }}
      >
        <thead>
          <tr style={{ background: 'var(--theme-card2, rgba(255,255,255,0.02))' }}>
            <Th>Datum</Th>
            {showItem && <Th>Item</Th>}
            <Th>Locatie</Th>
            <Th align="right">Delta</Th>
            <Th>Reden</Th>
            <Th>Actor</Th>
            <Th>Notitie</Th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr
              key={row.id}
              style={{
                borderTop: '1px solid var(--theme-border, rgba(255,255,255,0.06))',
              }}
            >
              <Td>
                <div style={{ fontSize: 13 }}>{formatDate(row.createdAt)}</div>
              </Td>
              {showItem && (
                <Td>
                  <code style={{ fontSize: 13 }}>{row.itemSku ?? row.itemId.slice(0, 8)}</code>
                </Td>
              )}
              <Td>
                {row.location.name ?? <span className="muted">—</span>}
                {row.location.code && (
                  <span className="muted" style={{ fontSize: 12, marginLeft: 4 }}>
                    ({row.location.code})
                  </span>
                )}
              </Td>
              <Td align="right">
                <DeltaBadge delta={row.delta} />
              </Td>
              <Td>
                <span
                  className="pill"
                  style={{ fontSize: 11, textTransform: 'capitalize' }}
                >
                  {row.reason}
                </span>
              </Td>
              <Td>
                <span style={{ fontSize: 13 }}>
                  {row.actor?.email ?? <span className="muted">system</span>}
                </span>
              </Td>
              <Td>
                <span
                  title={row.note ?? undefined}
                  style={{
                    display: 'block',
                    maxWidth: 240,
                    overflow: 'hidden',
                    textOverflow: 'ellipsis',
                    whiteSpace: 'nowrap',
                    fontSize: 13,
                    color: 'var(--theme-muted)',
                  }}
                >
                  {row.note ?? '—'}
                </span>
              </Td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}

function DeltaBadge({ delta }: { delta: number }) {
  const positive = delta > 0;
  const zero = delta === 0;
  return (
    <span
      style={{
        display: 'inline-block',
        padding: '2px 8px',
        borderRadius: 4,
        fontWeight: 600,
        fontSize: 13,
        background: positive
          ? 'rgba(34,197,94,0.12)'
          : zero
            ? 'rgba(255,255,255,0.06)'
            : 'rgba(239,68,68,0.12)',
        color: positive ? '#86efac' : zero ? 'var(--theme-muted)' : '#fca5a5',
      }}
    >
      {delta > 0 ? '+' : ''}
      {delta}
    </span>
  );
}

function Th({
  children,
  align,
}: {
  children: React.ReactNode;
  align?: 'left' | 'right' | 'center';
}) {
  return (
    <th
      style={{
        textAlign: align ?? 'left',
        padding: '10px 14px',
        fontWeight: 600,
        fontSize: 12,
        textTransform: 'uppercase',
        color: 'var(--theme-muted)',
        letterSpacing: 0.4,
      }}
    >
      {children}
    </th>
  );
}

function Td({
  children,
  align,
}: {
  children: React.ReactNode;
  align?: 'left' | 'right' | 'center';
}) {
  return (
    <td
      style={{
        textAlign: align ?? 'left',
        padding: '10px 14px',
        verticalAlign: 'top',
      }}
    >
      {children}
    </td>
  );
}

function formatDate(input: string | Date): string {
  const d = typeof input === 'string' ? new Date(input) : input;
  if (Number.isNaN(d.getTime())) return '—';
  // 09 mei 14:23
  return d.toLocaleString('nl-NL', {
    day: '2-digit',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit',
  });
}
