import { createFileRoute, Outlet, redirect } from '@tanstack/react-router';
import { Sidebar } from '@/components/Sidebar';
import { api, asApiError } from '@/lib/api';
import { AUTH_QUERY_KEY, type AuthUser } from '@/lib/auth';

export const Route = createFileRoute('/_app')({
  beforeLoad: async ({ context, location }) => {
    // Check cached first to avoid extra request when navigating between pages
    const cached = context.queryClient.getQueryData<AuthUser | null>([...AUTH_QUERY_KEY]);
    if (cached) return;

    try {
      const res = await api.get<{ user: AuthUser }>('/auth/me');
      context.queryClient.setQueryData([...AUTH_QUERY_KEY], res.data.user);
    } catch (err) {
      const e = asApiError(err);
      if (e.status === 401) {
        throw redirect({
          to: '/login',
          search: { from: location.href },
        });
      }
      // andere fout: log + laat door (UI zal zelf error tonen)
      console.error('auth-check failed', e);
    }
  },
  component: AppLayout,
});

function AppLayout() {
  return (
    <div className="app-shell">
      <Sidebar />
      <main className="app-main">
        <Outlet />
      </main>
    </div>
  );
}
