import { createFileRoute, Link, notFound } from '@tanstack/react-router';
import { useEffect, useMemo, useState, type FormEvent } from 'react';
import {
  ChevronLeft, Printer, RefreshCcw, X, Mail, Truck, Package, CheckCheck, MapPin, User, FileText,
} from 'lucide-react';
import { getOrder, getOrderEvents, type OrderStatus } from '@/lib/mock-data-extended';
import { ChannelPill, OrderStatusPill, PaymentStatusPill } from '@/components/orders/Pills';
import { formatMoney, formatDateTime } from '@/lib/format';
import { useOrders, orderActions } from '@/lib/mock-state';
import { Modal } from '@/components/ui/Modal';
import { ConfirmDialog } from '@/components/ui/ConfirmDialog';
import { FormField } from '@/components/ui/FormField';
import { toast } from '@/lib/toast';

export const Route = createFileRoute('/_app/orders/$id')({
  component: OrderDetailPage,
  loader: ({ params }) => {
    const order = orderActions.get(params.id) ?? getOrder(params.id);
    if (!order) throw notFound();
    return { orderNumber: order.number };
  },
});

const FULFILLMENT_STEPS = [
  { key: 'allocated' as OrderStatus, label: 'Allocated', icon: Package },
  { key: 'picked' as OrderStatus, label: 'Picked', icon: CheckCheck },
  { key: 'shipped' as OrderStatus, label: 'Shipped', icon: Truck },
  { key: 'delivered' as OrderStatus, label: 'Delivered', icon: CheckCheck },
];

const STATUS_RANK: Record<OrderStatus, number> = {
  open: 0,
  allocated: 1,
  picked: 2,
  shipped: 3,
  delivered: 4,
  cancelled: -1,
};

function OrderDetailPage() {
  const { orderNumber } = Route.useLoaderData();
  const orders = useOrders();
  const order = useMemo(() => orders.find((o) => o.number === orderNumber), [orders, orderNumber]);

  const [labelOpen, setLabelOpen] = useState(false);
  const [refundOpen, setRefundOpen] = useState(false);
  const [confirmCancel, setConfirmCancel] = useState(false);

  if (!order) {
    return (
      <div className="empty-state">
        <h2>Order niet gevonden</h2>
        <p>De order is mogelijk verwijderd of het nummer klopt niet.</p>
        <Link to="/orders" className="btn btn-secondary" style={{ marginTop: 12 }}>
          Terug naar orders
        </Link>
      </div>
    );
  }

  const events = getOrderEvents(order);
  const stepIndex = STATUS_RANK[order.status];

  function nextStatus(): { label: string; status: OrderStatus } | null {
    if (order!.status === 'open') return { label: 'Markeer Allocated', status: 'allocated' };
    if (order!.status === 'allocated') return { label: 'Markeer Picked', status: 'picked' };
    if (order!.status === 'picked') return { label: 'Markeer Shipped', status: 'shipped' };
    if (order!.status === 'shipped') return { label: 'Markeer Delivered', status: 'delivered' };
    return null;
  }

  function advance() {
    const next = nextStatus();
    if (!next) return;
    orderActions.setStatus(order!.id, next.status);
    const labelMap: Record<OrderStatus, string> = {
      open: 'open',
      allocated: 'gealloceerd',
      picked: 'gepakt',
      shipped: 'verzonden',
      delivered: 'bezorgd',
      cancelled: 'geannuleerd',
    };
    toast.success(`Order ${order!.number} gemarkeerd als ${labelMap[next.status]}`);
  }

  return (
    <div>
      <div style={{ marginBottom: 8 }}>
        <Link to="/orders" className="btn btn-ghost btn-sm" style={{ paddingLeft: 6 }}>
          <ChevronLeft size={14} />
          Terug naar orders
        </Link>
      </div>
      <div className="page-header">
        <div>
          <div style={{ fontSize: 11.5, color: 'var(--text-faint)', letterSpacing: '0.04em', textTransform: 'uppercase' }}>
            Order
          </div>
          <div className="page-title-row">
            <h1 className="page-title mono" style={{ fontFamily: 'inherit' }}>{order.number}</h1>
            <OrderStatusPill status={order.status} />
            <PaymentStatusPill status={order.paymentStatus} />
            <ChannelPill slug={order.channel} />
          </div>
          <p className="page-subtitle">
            Geplaatst {formatDateTime(order.createdAt)} • {order.itemsCount} items • {formatMoney(order.total)}
          </p>
        </div>
        <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
          <button
            type="button"
            className="btn btn-secondary"
            onClick={() => toast.info('Factuur-print komt in Fase 4')}
          >
            <Printer size={14} /> Factuur
          </button>
          <button
            type="button"
            className="btn btn-secondary"
            onClick={() => toast.success(`Bevestiging opnieuw verstuurd naar ${order.customerName}`)}
          >
            <Mail size={14} /> Bevestiging
          </button>
          <button
            type="button"
            className="btn btn-primary"
            onClick={() => setLabelOpen(true)}
            disabled={order.status === 'cancelled'}
          >
            <Truck size={14} /> Verzendlabel
          </button>
        </div>
      </div>

      <div className="detail-grid">
        {/* Main column */}
        <div className="section-stack">
          {/* Items card */}
          <div className="card card-flush">
            <div style={{ padding: '16px 20px', borderBottom: '1px solid var(--border-default)' }}>
              <h2 className="card-title">Items ({order.lines.length})</h2>
            </div>
            <table className="table" style={{ borderRadius: 0 }}>
              <thead>
                <tr>
                  <th>Product</th>
                  <th style={{ textAlign: 'right' }}>Aantal</th>
                  <th style={{ textAlign: 'right' }}>Prijs</th>
                  <th style={{ textAlign: 'right' }}>Totaal</th>
                </tr>
              </thead>
              <tbody>
                {order.lines.map((l) => (
                  <tr key={l.id}>
                    <td>
                      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
                        <div style={{
                          width: 40, height: 40, borderRadius: 6, overflow: 'hidden',
                          background: 'var(--surface-1)', border: '1px solid var(--border-subtle)',
                          flexShrink: 0,
                        }}>
                          {l.imageUrl ? (
                            <img src={l.imageUrl} alt={l.title} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                          ) : (
                            <div style={{ width: '100%', height: '100%', display: 'grid', placeItems: 'center', color: 'var(--text-faint)' }}>
                              <Package size={16} />
                            </div>
                          )}
                        </div>
                        <div>
                          <div style={{ fontWeight: 500 }}>{l.title}</div>
                          <div className="mono" style={{ color: 'var(--theme-muted)' }}>{l.variantSku} • BTW {l.vatRate}%</div>
                        </div>
                      </div>
                    </td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{l.qty}×</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{formatMoney(l.unitPrice)}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(l.lineTotal)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Fulfillment card */}
          <div className="card">
            <div className="card-header">
              <h2 className="card-title">Fulfillment</h2>
              {order.trackingNumber && (
                <span className="badge badge-info mono" style={{ fontSize: 11 }}>{order.trackingNumber}</span>
              )}
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: `repeat(${FULFILLMENT_STEPS.length}, 1fr)`, gap: 8, position: 'relative' }}>
              {FULFILLMENT_STEPS.map((step, i) => {
                const Icon = step.icon;
                const done = stepIndex >= 0 && stepIndex >= STATUS_RANK[step.key];
                const active = order.status === step.key;
                const reachable =
                  order.status !== 'cancelled' &&
                  stepIndex >= 0 &&
                  STATUS_RANK[step.key] === stepIndex + 1;
                return (
                  <button
                    type="button"
                    key={step.key}
                    onClick={() => {
                      if (!reachable) return;
                      orderActions.setStatus(order.id, step.key);
                      toast.success(`Status → ${step.label}`);
                    }}
                    disabled={!reachable && !done}
                    title={reachable ? `Klik om naar ${step.label} te gaan` : undefined}
                    style={{
                      display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 6,
                      background: 'transparent', border: 'none', padding: 8, borderRadius: 8,
                      cursor: reachable ? 'pointer' : 'default',
                    }}
                  >
                    <div style={{
                      width: 36, height: 36, borderRadius: '50%',
                      display: 'grid', placeItems: 'center',
                      background: done ? 'var(--theme-accent)' : reachable ? 'var(--theme-accent-subtle)' : 'var(--surface-3)',
                      color: done ? '#170f07' : reachable ? 'var(--theme-accent)' : 'var(--theme-muted)',
                      border: active ? '2px solid var(--theme-accent)' : reachable ? '1px dashed var(--theme-accent-border)' : '1px solid var(--border-default)',
                      transition: 'all 200ms',
                    }}>
                      <Icon size={16} strokeWidth={2.2} />
                    </div>
                    <div style={{ fontSize: 12, fontWeight: 500, color: done ? 'var(--theme-text)' : 'var(--theme-muted)' }}>
                      {step.label}
                    </div>
                  </button>
                );
              })}
            </div>
            <div style={{ marginTop: 16, paddingTop: 14, borderTop: '1px solid var(--border-subtle)', display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 8 }}>
              <span style={{ fontSize: 13, color: 'var(--theme-muted)' }}>
                Methode: <strong style={{ color: 'var(--theme-text)' }}>{order.shippingMethod}</strong>
              </span>
              <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
                {nextStatus() && (
                  <button type="button" className="btn btn-primary btn-sm" onClick={advance}>
                    {nextStatus()!.label}
                  </button>
                )}
                <button
                  type="button"
                  className="btn btn-secondary btn-sm"
                  onClick={() => toast.info('Pak-bon-print komt in Fase 4')}
                >
                  <Printer size={13} /> Pak-bon
                </button>
              </div>
            </div>
          </div>

          {/* Timeline card */}
          <div className="card">
            <div className="card-header">
              <h2 className="card-title">Tijdlijn</h2>
            </div>
            <div className="activity-feed">
              {events.map((e, i) => (
                <div key={i} className="activity-item">
                  <div className={`activity-icon ${
                    e.kind === 'paid' ? 'icon-product' :
                    e.kind === 'shipped' || e.kind === 'delivered' ? 'icon-stock' : 'icon-order'
                  }`}>
                    {e.kind === 'created' && <FileText size={14} />}
                    {e.kind === 'paid' && <CheckCheck size={14} />}
                    {e.kind === 'allocated' && <Package size={14} />}
                    {e.kind === 'picked' && <CheckCheck size={14} />}
                    {e.kind === 'shipped' && <Truck size={14} />}
                    {e.kind === 'delivered' && <CheckCheck size={14} />}
                    {e.kind === 'cancelled' && <X size={14} />}
                  </div>
                  <div className="activity-text">
                    <div><strong>{e.label}</strong></div>
                    <div className="activity-actor">{e.description}</div>
                  </div>
                  <div className="activity-time">{formatDateTime(e.at)}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Aside */}
        <div className="aside-stack">
          <div className="card">
            <div className="card-header"><h2 className="card-title">Klant</h2></div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              <div className="avatar" style={{ width: 36, height: 36 }}>
                <User size={16} />
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontWeight: 600 }}>{order.customerName}</div>
                <div className="mono" style={{ color: 'var(--theme-muted)' }}>{order.shippingAddress.country}</div>
              </div>
            </div>
            <div className="divider" />
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: 13 }}>
              <Link to="/customers" className="btn btn-ghost btn-sm" style={{ justifyContent: 'flex-start' }}>
                Bekijk klant-profiel →
              </Link>
            </div>
          </div>

          <div className="card">
            <div className="card-header">
              <h2 className="card-title"><MapPin size={14} style={{ display: 'inline', verticalAlign: -2 }} /> Adres</h2>
            </div>
            <div style={{ fontSize: 13, lineHeight: 1.55 }}>
              <div style={{ fontWeight: 600 }}>{order.shippingAddress.name}</div>
              <div className="muted">{order.shippingAddress.street}</div>
              <div className="muted">{order.shippingAddress.zip} {order.shippingAddress.city}</div>
              <div className="muted">{order.shippingAddress.country}</div>
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">Betaling</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 8, fontSize: 13 }}>
              <Row label="Subtotaal (excl. BTW)" value={formatMoney(order.subtotalExclVat)} />
              {order.vatBreakdown.map((v) => (
                <Row key={v.label} label={v.label} value={formatMoney(v.amount)} />
              ))}
              <Row label="Verzending" value={formatMoney(order.shippingAmount)} />
              {order.discountAmount > 0 && (
                <Row label="Korting" value={`− ${formatMoney(order.discountAmount)}`} accent="danger" />
              )}
              <div className="divider" style={{ margin: '4px 0' }} />
              <Row label="Totaal" value={formatMoney(order.total)} bold />
              <div style={{ marginTop: 8, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <PaymentStatusPill status={order.paymentStatus} />
                <span style={{ fontSize: 12, color: 'var(--theme-muted)' }}>{order.paymentMethod}</span>
              </div>
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">BTW</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: 13 }}>
              <Row label="Scheme" value={order.vatScheme} />
              <Row label="BTW-bedrag" value={formatMoney(order.vatAmount)} />
              {order.invoiceNumber && (
                <Row label="Factuur" value={order.invoiceNumber} mono />
              )}
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">Acties</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
              <button
                type="button"
                className="btn btn-secondary btn-sm"
                style={{ justifyContent: 'flex-start' }}
                onClick={() => setRefundOpen(true)}
                disabled={order.paymentStatus === 'refunded'}
              >
                <RefreshCcw size={13} /> Refund verwerken
              </button>
              <button
                type="button"
                className="btn btn-secondary btn-sm"
                style={{ justifyContent: 'flex-start' }}
                onClick={() => toast.success(`Bevestigingsmail verstuurd (mock) naar ${order.customerName}`)}
              >
                <Mail size={13} /> Stuur bevestiging opnieuw
              </button>
              {order.status !== 'cancelled' && order.status !== 'delivered' && (
                <button
                  type="button"
                  className="btn btn-danger btn-sm"
                  style={{ justifyContent: 'flex-start' }}
                  onClick={() => setConfirmCancel(true)}
                >
                  <X size={13} /> Annuleer order
                </button>
              )}
            </div>
          </div>
        </div>
      </div>

      <LabelModal
        open={labelOpen}
        onClose={() => setLabelOpen(false)}
        orderId={order.id}
        orderNumber={order.number}
      />
      <RefundModal
        open={refundOpen}
        onClose={() => setRefundOpen(false)}
        orderId={order.id}
        orderNumber={order.number}
        maxAmount={order.total}
      />
      <ConfirmDialog
        open={confirmCancel}
        onClose={() => setConfirmCancel(false)}
        onConfirm={() => {
          orderActions.cancel(order.id);
          toast.success(`Order ${order.number} geannuleerd`);
        }}
        title="Order annuleren?"
        message={
          <>
            Annuleer <strong>{order.number}</strong>? De voorraad-allocatie zou normaal worden vrijgegeven.
            In demo wordt alleen de status bijgewerkt.
          </>
        }
        confirmLabel="Ja, annuleer"
      />
    </div>
  );
}

function Row({ label, value, bold = false, mono = false, accent }: {
  label: string; value: string; bold?: boolean; mono?: boolean; accent?: 'danger';
}) {
  return (
    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: 8 }}>
      <span style={{ color: 'var(--theme-muted)' }}>{label}</span>
      <span
        className={mono ? 'mono' : ''}
        style={{
          fontWeight: bold ? 700 : 500,
          fontSize: bold ? 14 : 13,
          color: accent === 'danger' ? 'var(--danger)' : 'var(--theme-text)',
          fontVariantNumeric: 'tabular-nums',
        }}
      >
        {value}
      </span>
    </div>
  );
}

/* ─── Label-modal ──────────────────────────────────────────── */

function LabelModal({
  open, onClose, orderId, orderNumber,
}: { open: boolean; onClose: () => void; orderId: string; orderNumber: string }) {
  const [carrier, setCarrier] = useState('PostNL');
  const [weight, setWeight] = useState(1.5);
  const [length, setLength] = useState(30);
  const [width, setWidth] = useState(20);
  const [height, setHeight] = useState(10);
  const [busy, setBusy] = useState(false);

  useEffect(() => {
    if (open) {
      setCarrier('PostNL');
      setWeight(1.5);
      setLength(30);
      setWidth(20);
      setHeight(10);
      setBusy(false);
    }
  }, [open]);

  function onSubmit(e: FormEvent) {
    e.preventDefault();
    setBusy(true);
    setTimeout(() => {
      const tn = orderActions.generateTrackingNumber(orderId, carrier);
      toast.success(`Label ${tn} gegenereerd via ${carrier}`);
      setBusy(false);
      onClose();
    }, 600);
  }

  return (
    <Modal
      open={open}
      onClose={onClose}
      title={`Verzendlabel — ${orderNumber}`}
      subtitle="Kies vervoerder en pakket-afmetingen."
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>Annuleer</button>
          <button type="submit" form="label-form" className="btn btn-primary" disabled={busy}>
            {busy ? 'Genereren…' : 'Label genereren'}
          </button>
        </>
      }
    >
      <form id="label-form" onSubmit={onSubmit}>
        <FormField label="Vervoerder">
          <select value={carrier} onChange={(e) => setCarrier(e.target.value)}>
            <option>PostNL</option>
            <option>DHL</option>
            <option>DPD</option>
            <option>UPS</option>
          </select>
        </FormField>
        <FormField label="Gewicht (kg)">
          <input type="number" min="0.1" step="0.1" value={weight} onChange={(e) => setWeight(Number(e.target.value))} />
        </FormField>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8 }}>
          <FormField label="Lengte (cm)">
            <input type="number" min="1" value={length} onChange={(e) => setLength(Number(e.target.value))} />
          </FormField>
          <FormField label="Breedte (cm)">
            <input type="number" min="1" value={width} onChange={(e) => setWidth(Number(e.target.value))} />
          </FormField>
          <FormField label="Hoogte (cm)">
            <input type="number" min="1" value={height} onChange={(e) => setHeight(Number(e.target.value))} />
          </FormField>
        </div>
      </form>
    </Modal>
  );
}

/* ─── Refund-modal ─────────────────────────────────────────── */

function RefundModal({
  open, onClose, orderId, orderNumber, maxAmount,
}: { open: boolean; onClose: () => void; orderId: string; orderNumber: string; maxAmount: number }) {
  const [amount, setAmount] = useState(maxAmount);
  const [reason, setReason] = useState('Klant niet tevreden');
  const [partial, setPartial] = useState(false);
  const [busy, setBusy] = useState(false);

  useEffect(() => {
    if (open) {
      setAmount(maxAmount);
      setReason('Klant niet tevreden');
      setPartial(false);
      setBusy(false);
    }
  }, [open, maxAmount]);

  function onSubmit(e: FormEvent) {
    e.preventDefault();
    if (amount <= 0 || amount > maxAmount) {
      toast.error(`Bedrag moet tussen €0 en ${formatMoney(maxAmount)} zijn`);
      return;
    }
    setBusy(true);
    setTimeout(() => {
      orderActions.update(orderId, {
        paymentStatus: partial || amount < maxAmount ? 'partially_refunded' : 'refunded',
      });
      toast.success(`Refund van ${formatMoney(amount)} verwerkt voor ${orderNumber}`);
      setBusy(false);
      onClose();
    }, 500);
  }

  return (
    <Modal
      open={open}
      onClose={onClose}
      title={`Refund — ${orderNumber}`}
      subtitle={`Maximum: ${formatMoney(maxAmount)}`}
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>Annuleer</button>
          <button type="submit" form="refund-form" className="btn btn-primary" disabled={busy}>
            {busy ? 'Verwerken…' : 'Refund verwerken'}
          </button>
        </>
      }
    >
      <form id="refund-form" onSubmit={onSubmit}>
        <FormField label="Bedrag">
          <input
            type="number"
            min="0"
            step="0.01"
            max={maxAmount}
            value={amount}
            onChange={(e) => {
              const v = Number(e.target.value);
              setAmount(v);
              setPartial(v < maxAmount);
            }}
          />
        </FormField>
        <FormField label="Reden">
          <select value={reason} onChange={(e) => setReason(e.target.value)}>
            <option>Klant niet tevreden</option>
            <option>Product defect</option>
            <option>Verkeerd verstuurd</option>
            <option>Goodwill-actie</option>
            <option>Anders</option>
          </select>
        </FormField>
        <label style={{ display: 'flex', alignItems: 'center', gap: 6, fontSize: 12.5, color: 'var(--theme-muted)' }}>
          <input type="checkbox" checked={partial} onChange={(e) => setPartial(e.target.checked)} style={{ width: 14, height: 14, padding: 0 }} />
          Markeer als gedeeltelijke refund
        </label>
      </form>
    </Modal>
  );
}
