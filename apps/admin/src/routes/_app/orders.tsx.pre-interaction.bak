import { createFileRoute, Link } from '@tanstack/react-router';
import { useMemo, useState } from 'react';
import { Search, Plus, ShoppingCart, Truck, CalendarDays, Euro } from 'lucide-react';
import { MOCK_ORDERS, type OrderStatus, type ChannelSlug } from '@/lib/mock-data-extended';
import { ChannelPill, OrderStatusPill, PaymentStatusPill } from '@/components/orders/Pills';
import { formatMoney, formatDateTime } from '@/lib/format';

export const Route = createFileRoute('/_app/orders')({
  component: OrdersPage,
});

const STATUS_TABS: Array<{ value: OrderStatus | 'all'; label: string }> = [
  { value: 'all', label: 'Alle' },
  { value: 'open', label: 'Open' },
  { value: 'allocated', label: 'Allocated' },
  { value: 'picked', label: 'Picked' },
  { value: 'shipped', label: 'Verzonden' },
  { value: 'delivered', label: 'Bezorgd' },
  { value: 'cancelled', label: 'Geannuleerd' },
];

const CHANNEL_OPTIONS: Array<{ value: ChannelSlug; label: string }> = [
  { value: 'storefront-koffie', label: 'Crema & Co.' },
  { value: 'storefront-pawfect', label: 'Pawfect' },
  { value: 'bol', label: 'Bol.com' },
  { value: 'amazon-nl', label: 'Amazon NL' },
];

function OrdersPage() {
  const [search, setSearch] = useState('');
  const [statusTab, setStatusTab] = useState<OrderStatus | 'all'>('all');
  const [channelFilter, setChannelFilter] = useState<Set<ChannelSlug>>(new Set());

  const filtered = useMemo(() => {
    const q = search.trim().toLowerCase();
    return MOCK_ORDERS.filter((o) => {
      if (statusTab !== 'all' && o.status !== statusTab) return false;
      if (channelFilter.size > 0 && !channelFilter.has(o.channel)) return false;
      if (q) {
        const hay = `${o.number} ${o.customerName} ${o.lines.map((l) => l.variantSku).join(' ')}`.toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }, [search, statusTab, channelFilter]);

  const counts = useMemo(() => {
    const map: Record<string, number> = { all: MOCK_ORDERS.length };
    for (const o of MOCK_ORDERS) map[o.status] = (map[o.status] ?? 0) + 1;
    return map;
  }, []);

  // KPIs
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const openCount = MOCK_ORDERS.filter((o) => ['open', 'allocated'].includes(o.status)).length;
  const toShipCount = MOCK_ORDERS.filter((o) => ['allocated', 'picked'].includes(o.status)).length;
  const shippedToday = MOCK_ORDERS.filter((o) => o.shippedAt && new Date(o.shippedAt) >= today).length;
  const revenueToday = MOCK_ORDERS
    .filter((o) => new Date(o.createdAt) >= today)
    .reduce((s, o) => s + o.total, 0);

  function toggleChannel(c: ChannelSlug) {
    setChannelFilter((prev) => {
      const next = new Set(prev);
      if (next.has(c)) next.delete(c);
      else next.add(c);
      return next;
    });
  }

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Orders</h1>
            <span className="count-badge">{MOCK_ORDERS.length}</span>
          </div>
          <p className="page-subtitle">Alle orders over alle kanalen — eigen webshop, Bol, Amazon en meer.</p>
        </div>
        <button type="button" className="btn btn-primary">
          <Plus size={15} strokeWidth={2.2} />
          Handmatige order
        </button>
      </div>

      {/* KPI strip */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 16, marginBottom: 20 }}>
        <KpiCard icon={<ShoppingCart size={16} />} label="Open" value={String(openCount)} hint="te alloceren of pakken" accent="info" />
        <KpiCard icon={<Truck size={16} />} label="Te verzenden" value={String(toShipCount)} hint="picked + allocated" accent="warning" />
        <KpiCard icon={<CalendarDays size={16} />} label="Verzonden vandaag" value={String(shippedToday)} hint="laatste 24u" accent="success" />
        <KpiCard icon={<Euro size={16} />} label="Omzet vandaag" value={formatMoney(revenueToday, { decimals: false })} hint={`${MOCK_ORDERS.filter(o => new Date(o.createdAt) >= today).length} orders`} accent="accent" />
      </div>

      {/* Toolbar */}
      <div className="toolbar" style={{ marginBottom: 12 }}>
        <div className="search-input">
          <Search size={14} />
          <input
            placeholder="Zoek op order-nr, klant of SKU…"
            value={search}
            onChange={(e) => setSearch(e.target.value)}
          />
        </div>
        <div className="segmented" role="tablist">
          {STATUS_TABS.map((t) => (
            <button
              key={t.value}
              type="button"
              data-active={statusTab === t.value}
              onClick={() => setStatusTab(t.value)}
            >
              {t.label}
              <span className="seg-count">{counts[t.value] ?? 0}</span>
            </button>
          ))}
        </div>
      </div>

      <div className="toolbar" style={{ marginBottom: 16, gap: 6 }}>
        <span style={{ fontSize: 12, color: 'var(--theme-muted)', marginRight: 4 }}>Kanaal:</span>
        {CHANNEL_OPTIONS.map((c) => (
          <button
            key={c.value}
            type="button"
            className={`badge ${channelFilter.has(c.value) ? 'badge-accent' : ''}`}
            onClick={() => toggleChannel(c.value)}
            style={{ cursor: 'pointer', border: 'none', background: channelFilter.has(c.value) ? 'var(--theme-accent-subtle)' : 'var(--theme-card2)' }}
          >
            {c.label}
          </button>
        ))}
        {channelFilter.size > 0 && (
          <button type="button" className="btn btn-ghost btn-sm" onClick={() => setChannelFilter(new Set())}>
            Wis filters
          </button>
        )}
      </div>

      {/* Table */}
      {filtered.length === 0 ? (
        <div className="empty-state">
          <div className="empty-state-icon">
            <ShoppingCart size={22} />
          </div>
          <h2>Geen orders gevonden</h2>
          <p>Pas je zoekopdracht of filters aan om resultaten te zien.</p>
        </div>
      ) : (
        <div className="table-wrap">
          <div style={{ overflowX: 'auto' }}>
            <table className="table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Datum</th>
                  <th>Klant</th>
                  <th>Kanaal</th>
                  <th style={{ textAlign: 'right' }}>Items</th>
                  <th style={{ textAlign: 'right' }}>Totaal</th>
                  <th>Status</th>
                  <th>Betaling</th>
                  <th style={{ width: 40 }}></th>
                </tr>
              </thead>
              <tbody>
                {filtered.map((o) => (
                  <tr key={o.id}>
                    <td>
                      <Link
                        to="/orders/$id"
                        params={{ id: o.number }}
                        className="mono"
                        style={{ color: 'var(--theme-accent)', textDecoration: 'none', fontWeight: 600 }}
                      >
                        {o.number}
                      </Link>
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDateTime(o.createdAt)}</td>
                    <td>{o.customerName}</td>
                    <td><ChannelPill slug={o.channel} compact /></td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{o.itemsCount}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(o.total)}</td>
                    <td><OrderStatusPill status={o.status} /></td>
                    <td><PaymentStatusPill status={o.paymentStatus} /></td>
                    <td style={{ textAlign: 'right' }}>
                      <Link to="/orders/$id" params={{ id: o.number }} className="btn btn-ghost btn-sm">
                        ›
                      </Link>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

function KpiCard({
  icon, label, value, hint, accent,
}: {
  icon: React.ReactNode;
  label: string;
  value: string;
  hint?: string;
  accent: 'info' | 'warning' | 'success' | 'accent';
}) {
  const accentColor =
    accent === 'info' ? 'var(--info)'
    : accent === 'warning' ? 'var(--warning)'
    : accent === 'success' ? 'var(--success)'
    : 'var(--theme-accent)';
  return (
    <div className="kpi-card">
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span className="kpi-label">{label}</span>
        <span style={{ color: accentColor, display: 'inline-grid', placeItems: 'center' }}>{icon}</span>
      </div>
      <h2 className="kpi-value">{value}</h2>
      {hint && <p className="kpi-hint">{hint}</p>}
    </div>
  );
}
