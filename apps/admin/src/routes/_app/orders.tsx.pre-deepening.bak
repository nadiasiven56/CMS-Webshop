import { createFileRoute, Link, useNavigate } from '@tanstack/react-router';
import { useEffect, useMemo, useRef, useState, type FormEvent } from 'react';
import {
  Search, Plus, ShoppingCart, Truck, CalendarDays, Euro, MoreHorizontal,
  Printer, X as XIcon, Eye,
} from 'lucide-react';
import { type OrderStatus, type ChannelSlug, type MockOrder, type MockOrderLine } from '@/lib/mock-data-extended';
import { ChannelPill, OrderStatusPill, PaymentStatusPill } from '@/components/orders/Pills';
import { formatMoney, formatDateTime } from '@/lib/format';
import { useOrders, orderActions, useCustomers } from '@/lib/mock-state';
import { Drawer } from '@/components/ui/Drawer';
import { ConfirmDialog } from '@/components/ui/ConfirmDialog';
import { FormField } from '@/components/ui/FormField';
import { toast } from '@/lib/toast';

export const Route = createFileRoute('/_app/orders')({
  component: OrdersPage,
});

const STATUS_TABS: Array<{ value: OrderStatus | 'all'; label: string }> = [
  { value: 'all', label: 'Alle' },
  { value: 'open', label: 'Open' },
  { value: 'allocated', label: 'Allocated' },
  { value: 'picked', label: 'Picked' },
  { value: 'shipped', label: 'Verzonden' },
  { value: 'delivered', label: 'Bezorgd' },
  { value: 'cancelled', label: 'Geannuleerd' },
];

const CHANNEL_OPTIONS: Array<{ value: ChannelSlug; label: string }> = [
  { value: 'storefront-koffie', label: 'Crema & Co.' },
  { value: 'storefront-pawfect', label: 'Pawfect' },
  { value: 'bol', label: 'Bol.com' },
  { value: 'amazon-nl', label: 'Amazon NL' },
];

function OrdersPage() {
  const orders = useOrders();
  const customers = useCustomers();
  const navigate = useNavigate();

  const [searchInput, setSearchInput] = useState('');
  const [search, setSearch] = useState('');
  const [statusTab, setStatusTab] = useState<OrderStatus | 'all'>('all');
  const [channelFilter, setChannelFilter] = useState<Set<ChannelSlug>>(new Set());
  const [dateFrom, setDateFrom] = useState<string>('');
  const [dateTo, setDateTo] = useState<string>('');

  const [actionMenuFor, setActionMenuFor] = useState<string | null>(null);
  const [confirmCancel, setConfirmCancel] = useState<MockOrder | null>(null);
  const [createOpen, setCreateOpen] = useState(false);

  // Debounce search
  useEffect(() => {
    const t = setTimeout(() => setSearch(searchInput), 250);
    return () => clearTimeout(t);
  }, [searchInput]);

  // Close action-menu on outside click
  useEffect(() => {
    if (!actionMenuFor) return;
    function onClick() {
      setActionMenuFor(null);
    }
    window.addEventListener('click', onClick);
    return () => window.removeEventListener('click', onClick);
  }, [actionMenuFor]);

  const filtered = useMemo(() => {
    const q = search.trim().toLowerCase();
    const fromTs = dateFrom ? new Date(dateFrom).getTime() : -Infinity;
    const toTs = dateTo ? new Date(dateTo + 'T23:59:59').getTime() : Infinity;
    return orders.filter((o) => {
      if (statusTab !== 'all' && o.status !== statusTab) return false;
      if (channelFilter.size > 0 && !channelFilter.has(o.channel)) return false;
      const ts = new Date(o.createdAt).getTime();
      if (ts < fromTs || ts > toTs) return false;
      if (q) {
        const hay = `${o.number} ${o.customerName} ${o.lines.map((l) => l.variantSku).join(' ')}`.toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }, [orders, search, statusTab, channelFilter, dateFrom, dateTo]);

  const counts = useMemo(() => {
    const map: Record<string, number> = { all: orders.length };
    for (const o of orders) map[o.status] = (map[o.status] ?? 0) + 1;
    return map;
  }, [orders]);

  // KPIs
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const openCount = orders.filter((o) => ['open', 'allocated'].includes(o.status)).length;
  const toShipCount = orders.filter((o) => ['allocated', 'picked'].includes(o.status)).length;
  const shippedToday = orders.filter((o) => o.shippedAt && new Date(o.shippedAt) >= today).length;
  const revenueToday = orders
    .filter((o) => new Date(o.createdAt) >= today)
    .reduce((s, o) => s + o.total, 0);

  function toggleChannel(c: ChannelSlug) {
    setChannelFilter((prev) => {
      const next = new Set(prev);
      if (next.has(c)) next.delete(c);
      else next.add(c);
      return next;
    });
  }

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Orders</h1>
            <span className="count-badge">{orders.length}</span>
          </div>
          <p className="page-subtitle">Alle orders over alle kanalen — eigen webshop, Bol, Amazon en meer.</p>
        </div>
        <button type="button" className="btn btn-primary" onClick={() => setCreateOpen(true)}>
          <Plus size={15} strokeWidth={2.2} />
          Handmatige order
        </button>
      </div>

      {/* KPI strip */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 16, marginBottom: 20 }}>
        <KpiCard icon={<ShoppingCart size={16} />} label="Open" value={String(openCount)} hint="te alloceren of pakken" accent="info" onClick={() => setStatusTab('open')} />
        <KpiCard icon={<Truck size={16} />} label="Te verzenden" value={String(toShipCount)} hint="picked + allocated" accent="warning" onClick={() => setStatusTab('allocated')} />
        <KpiCard icon={<CalendarDays size={16} />} label="Verzonden vandaag" value={String(shippedToday)} hint="laatste 24u" accent="success" />
        <KpiCard icon={<Euro size={16} />} label="Omzet vandaag" value={formatMoney(revenueToday, { decimals: false })} hint={`${orders.filter(o => new Date(o.createdAt) >= today).length} orders`} accent="accent" />
      </div>

      {/* Toolbar */}
      <div className="toolbar" style={{ marginBottom: 12 }}>
        <div className="search-input">
          <Search size={14} />
          <input
            placeholder="Zoek op order-nr, klant of SKU…"
            value={searchInput}
            onChange={(e) => setSearchInput(e.target.value)}
          />
        </div>
        <div className="segmented" role="tablist">
          {STATUS_TABS.map((t) => (
            <button
              key={t.value}
              type="button"
              data-active={statusTab === t.value}
              onClick={() => setStatusTab(t.value)}
            >
              {t.label}
              <span className="seg-count">{counts[t.value] ?? 0}</span>
            </button>
          ))}
        </div>
      </div>

      <div className="toolbar" style={{ marginBottom: 16, gap: 6, alignItems: 'center' }}>
        <span style={{ fontSize: 12, color: 'var(--theme-muted)', marginRight: 4 }}>Kanaal:</span>
        {CHANNEL_OPTIONS.map((c) => (
          <button
            key={c.value}
            type="button"
            className={`badge ${channelFilter.has(c.value) ? 'badge-accent' : ''}`}
            onClick={() => toggleChannel(c.value)}
            style={{ cursor: 'pointer', border: 'none', background: channelFilter.has(c.value) ? 'var(--theme-accent-subtle)' : 'var(--theme-card2)' }}
          >
            {c.label}
          </button>
        ))}
        <span style={{ marginLeft: 12, fontSize: 12, color: 'var(--theme-muted)' }}>Periode:</span>
        <input
          type="date"
          value={dateFrom}
          onChange={(e) => setDateFrom(e.target.value)}
          style={{ padding: '5px 8px', fontSize: 12.5 }}
          aria-label="Vanaf"
        />
        <span style={{ color: 'var(--text-faint)', fontSize: 12 }}>→</span>
        <input
          type="date"
          value={dateTo}
          onChange={(e) => setDateTo(e.target.value)}
          style={{ padding: '5px 8px', fontSize: 12.5 }}
          aria-label="Tot"
        />
        {(channelFilter.size > 0 || dateFrom || dateTo) && (
          <button
            type="button"
            className="btn btn-ghost btn-sm"
            onClick={() => {
              setChannelFilter(new Set());
              setDateFrom('');
              setDateTo('');
            }}
          >
            Wis filters
          </button>
        )}
      </div>

      {/* Table */}
      {filtered.length === 0 ? (
        <div className="empty-state">
          <div className="empty-state-icon">
            <ShoppingCart size={22} />
          </div>
          <h2>Geen orders gevonden</h2>
          <p>Pas je zoekopdracht of filters aan om resultaten te zien.</p>
        </div>
      ) : (
        <div className="table-wrap">
          <div style={{ overflowX: 'auto' }}>
            <table className="table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Datum</th>
                  <th>Klant</th>
                  <th>Kanaal</th>
                  <th style={{ textAlign: 'right' }}>Items</th>
                  <th style={{ textAlign: 'right' }}>Totaal</th>
                  <th>Status</th>
                  <th>Betaling</th>
                  <th style={{ width: 40 }}></th>
                </tr>
              </thead>
              <tbody>
                {filtered.map((o) => (
                  <tr
                    key={o.id}
                    onClick={(e) => {
                      // Prevent row navigate when clicking action-menu button or link
                      const target = e.target as HTMLElement;
                      if (target.closest('button, a')) return;
                      void navigate({ to: '/orders/$id', params: { id: o.number } });
                    }}
                    style={{ cursor: 'pointer' }}
                  >
                    <td>
                      <Link
                        to="/orders/$id"
                        params={{ id: o.number }}
                        className="mono"
                        style={{ color: 'var(--theme-accent)', textDecoration: 'none', fontWeight: 600 }}
                      >
                        {o.number}
                      </Link>
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDateTime(o.createdAt)}</td>
                    <td>{o.customerName}</td>
                    <td><ChannelPill slug={o.channel} compact /></td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{o.itemsCount}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(o.total)}</td>
                    <td><OrderStatusPill status={o.status} /></td>
                    <td><PaymentStatusPill status={o.paymentStatus} /></td>
                    <td style={{ textAlign: 'right', position: 'relative' }}>
                      <button
                        type="button"
                        className="btn btn-ghost btn-sm"
                        onClick={(e) => {
                          e.stopPropagation();
                          setActionMenuFor(actionMenuFor === o.id ? null : o.id);
                        }}
                        aria-label="Acties"
                      >
                        <MoreHorizontal size={14} />
                      </button>
                      {actionMenuFor === o.id && (
                        <div
                          onClick={(e) => e.stopPropagation()}
                          style={{
                            position: 'absolute',
                            top: '100%',
                            right: 8,
                            zIndex: 20,
                            background: 'var(--theme-card)',
                            border: '1px solid var(--border-strong)',
                            borderRadius: 10,
                            boxShadow: 'var(--shadow-lg)',
                            minWidth: 180,
                            padding: 4,
                            display: 'flex',
                            flexDirection: 'column',
                          }}
                        >
                          <ActionMenuItem
                            icon={<Eye size={13} />}
                            label="Open"
                            onClick={() => {
                              setActionMenuFor(null);
                              void navigate({ to: '/orders/$id', params: { id: o.number } });
                            }}
                          />
                          <ActionMenuItem
                            icon={<Printer size={13} />}
                            label="Print factuur"
                            onClick={() => {
                              setActionMenuFor(null);
                              toast.info('Factuur-printen komt in Fase 4');
                            }}
                          />
                          {o.status !== 'cancelled' && o.status !== 'delivered' && (
                            <ActionMenuItem
                              icon={<XIcon size={13} />}
                              label="Annuleer order"
                              danger
                              onClick={() => {
                                setActionMenuFor(null);
                                setConfirmCancel(o);
                              }}
                            />
                          )}
                        </div>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <ConfirmDialog
        open={confirmCancel !== null}
        onClose={() => setConfirmCancel(null)}
        onConfirm={() => {
          if (confirmCancel) {
            orderActions.cancel(confirmCancel.id);
            toast.success(`Order ${confirmCancel.number} geannuleerd`);
          }
        }}
        title="Order annuleren?"
        message={
          <>
            Weet je zeker dat je <strong>{confirmCancel?.number}</strong> wilt annuleren? Dit zet de status op{' '}
            <em>cancelled</em>. Eventuele voorraad-allocatie wordt vrijgegeven (niet geïmplementeerd in demo).
          </>
        }
        confirmLabel="Ja, annuleer"
      />

      <CreateOrderDrawer
        open={createOpen}
        onClose={() => setCreateOpen(false)}
        customers={customers.map((c) => ({ id: c.id, label: c.fullName, email: c.email }))}
      />
    </div>
  );
}

function ActionMenuItem({
  icon, label, onClick, danger,
}: { icon: React.ReactNode; label: string; onClick: () => void; danger?: boolean }) {
  return (
    <button
      type="button"
      onClick={onClick}
      style={{
        display: 'flex',
        alignItems: 'center',
        gap: 8,
        padding: '7px 10px',
        background: 'transparent',
        border: 'none',
        borderRadius: 6,
        color: danger ? 'var(--danger)' : 'var(--theme-text)',
        textAlign: 'left',
        cursor: 'pointer',
        fontSize: 13,
      }}
      onMouseEnter={(e) => {
        (e.currentTarget as HTMLElement).style.background = 'var(--surface-3)';
      }}
      onMouseLeave={(e) => {
        (e.currentTarget as HTMLElement).style.background = 'transparent';
      }}
    >
      {icon}
      {label}
    </button>
  );
}

function KpiCard({
  icon, label, value, hint, accent, onClick,
}: {
  icon: React.ReactNode;
  label: string;
  value: string;
  hint?: string;
  accent: 'info' | 'warning' | 'success' | 'accent';
  onClick?: () => void;
}) {
  const accentColor =
    accent === 'info' ? 'var(--info)'
    : accent === 'warning' ? 'var(--warning)'
    : accent === 'success' ? 'var(--success)'
    : 'var(--theme-accent)';
  return (
    <div
      className="kpi-card"
      onClick={onClick}
      role={onClick ? 'button' : undefined}
      tabIndex={onClick ? 0 : undefined}
      style={{ cursor: onClick ? 'pointer' : undefined }}
    >
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span className="kpi-label">{label}</span>
        <span style={{ color: accentColor, display: 'inline-grid', placeItems: 'center' }}>{icon}</span>
      </div>
      <h2 className="kpi-value">{value}</h2>
      {hint && <p className="kpi-hint">{hint}</p>}
    </div>
  );
}

/* ─── Create-order drawer ─────────────────────────────────────────── */

interface CustomerOption {
  id: string;
  label: string;
  email: string;
}

function CreateOrderDrawer({
  open,
  onClose,
  customers,
}: {
  open: boolean;
  onClose: () => void;
  customers: CustomerOption[];
}) {
  const [customerId, setCustomerId] = useState('');
  const [sku, setSku] = useState('');
  const [qty, setQty] = useState(1);
  const [unitPrice, setUnitPrice] = useState(49.95);
  const [shippingMethod, setShippingMethod] = useState('PostNL Standard');
  const [submitting, setSubmitting] = useState(false);
  const firstFieldRef = useRef<HTMLSelectElement | null>(null);

  // Reset form on open
  useEffect(() => {
    if (open) {
      setCustomerId('');
      setSku('SKU-DEMO-001');
      setQty(1);
      setUnitPrice(49.95);
      setShippingMethod('PostNL Standard');
      setTimeout(() => firstFieldRef.current?.focus(), 50);
    }
  }, [open]);

  const total = useMemo(() => Math.round(qty * unitPrice * 100) / 100, [qty, unitPrice]);

  function onSubmit(e: FormEvent) {
    e.preventDefault();
    if (!customerId) {
      toast.error('Kies een klant');
      return;
    }
    setSubmitting(true);
    const customer = customers.find((c) => c.id === customerId);
    if (!customer) {
      toast.error('Klant niet gevonden');
      setSubmitting(false);
      return;
    }
    const orderNumber = `ORD-${Math.floor(Math.random() * 90000) + 10000}`;
    const subtotalExcl = Math.round((total / 1.21) * 100) / 100;
    const vat = Math.round((total - subtotalExcl) * 100) / 100;
    const line: MockOrderLine = {
      id: `line-${Date.now()}`,
      productId: 'prod-manual',
      variantSku: sku,
      title: `Handmatig: ${sku}`,
      qty,
      unitPrice,
      unitPriceExclVat: Math.round((unitPrice / 1.21) * 100) / 100,
      vatRate: 21,
      lineTotal: total,
      imageUrl: null,
    };
    const newOrder: MockOrder = {
      id: `manual-${Date.now()}`,
      number: orderNumber,
      channel: 'storefront-koffie',
      customerId: customer.id,
      customerName: customer.label,
      status: 'open',
      paymentStatus: 'pending',
      paymentMethod: 'Handmatig',
      currency: 'EUR',
      subtotalExclVat: subtotalExcl,
      vatAmount: vat,
      shippingAmount: 6.95,
      discountAmount: 0,
      total,
      vatScheme: 'NL-21',
      vatBreakdown: [{ rate: 21, base: subtotalExcl, amount: vat, label: 'NL 21%' }],
      shippingMethod,
      itemsCount: qty,
      lines: [line],
      createdAt: new Date().toISOString(),
      shippingAddress: { name: customer.label, street: 'Hoofdstraat 1', zip: '1000 AA', city: 'Amsterdam', country: 'NL' },
      billingAddress: { name: customer.label, street: 'Hoofdstraat 1', zip: '1000 AA', city: 'Amsterdam', country: 'NL' },
      notes: 'Handmatig aangemaakt vanuit admin',
    };
    setTimeout(() => {
      orderActions.add(newOrder);
      toast.success(`Order ${orderNumber} aangemaakt`);
      setSubmitting(false);
      onClose();
    }, 350);
  }

  return (
    <Drawer
      open={open}
      onClose={onClose}
      title="Handmatige order"
      subtitle="Maak een order aan zonder kassa-flow."
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>
            Annuleer
          </button>
          <button
            type="submit"
            form="create-order-form"
            className="btn btn-primary"
            disabled={submitting}
          >
            {submitting ? 'Aanmaken…' : 'Order aanmaken'}
          </button>
        </>
      }
    >
      <form id="create-order-form" onSubmit={onSubmit}>
        <FormField label="Klant" required>
          <select
            ref={firstFieldRef}
            value={customerId}
            onChange={(e) => setCustomerId(e.target.value)}
            required
          >
            <option value="">— Kies klant —</option>
            {customers.map((c) => (
              <option key={c.id} value={c.id}>
                {c.label} — {c.email}
              </option>
            ))}
          </select>
        </FormField>

        <div style={{ display: 'grid', gridTemplateColumns: '2fr 1fr 1fr', gap: 8, marginBottom: 14 }}>
          <FormField label="SKU" required>
            <input
              type="text"
              value={sku}
              onChange={(e) => setSku(e.target.value)}
              placeholder="SKU-001"
              required
            />
          </FormField>
          <FormField label="Aantal">
            <input
              type="number"
              min={1}
              value={qty}
              onChange={(e) => setQty(Math.max(1, Number(e.target.value)))}
            />
          </FormField>
          <FormField label="Prijs (incl)">
            <input
              type="number"
              min={0}
              step="0.01"
              value={unitPrice}
              onChange={(e) => setUnitPrice(Math.max(0, Number(e.target.value)))}
            />
          </FormField>
        </div>

        <FormField label="Verzendmethode">
          <select value={shippingMethod} onChange={(e) => setShippingMethod(e.target.value)}>
            <option>PostNL Standard</option>
            <option>PostNL Avond</option>
            <option>DHL ServicePoint</option>
            <option>DPD Pickup</option>
          </select>
        </FormField>

        <div
          style={{
            marginTop: 18,
            padding: '12px 14px',
            background: 'var(--surface-2)',
            border: '1px solid var(--border-subtle)',
            borderRadius: 10,
          }}
        >
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
            <span style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>Totaal (incl. BTW)</span>
            <strong style={{ fontSize: 18, color: 'var(--theme-text)', fontVariantNumeric: 'tabular-nums' }}>
              {formatMoney(total)}
            </strong>
          </div>
        </div>
      </form>
    </Drawer>
  );
}
