import { createFileRoute } from '@tanstack/react-router';
import { useMemo, useState } from 'react';
import { Plus, Truck, FileText, AlertCircle } from 'lucide-react';
import { MOCK_PURCHASE_ORDERS, MOCK_SUPPLIERS, type PoStatus } from '@/lib/mock-data-extended';
import { formatMoney, formatDate } from '@/lib/format';

export const Route = createFileRoute('/_app/purchase-orders')({
  component: PoPage,
});

const STATUS_TABS: Array<{ value: PoStatus | 'all'; label: string }> = [
  { value: 'all', label: 'Alle' },
  { value: 'draft', label: 'Concept' },
  { value: 'sent', label: 'Verzonden' },
  { value: 'confirmed', label: 'Bevestigd' },
  { value: 'partial', label: 'Deels' },
  { value: 'received', label: 'Ontvangen' },
  { value: 'closed', label: 'Gesloten' },
  { value: 'cancelled', label: 'Geannuleerd' },
];

const STATUS_BADGES: Record<PoStatus, { label: string; klass: string }> = {
  draft: { label: 'Concept', klass: 'badge-neutral' },
  sent: { label: 'Verzonden', klass: 'badge-info' },
  confirmed: { label: 'Bevestigd', klass: 'badge-warning' },
  partial: { label: 'Gedeeltelijk', klass: 'badge-warning' },
  received: { label: 'Ontvangen', klass: 'badge-success' },
  closed: { label: 'Gesloten', klass: 'badge-neutral' },
  cancelled: { label: 'Geannuleerd', klass: 'badge-danger' },
};

function PoPage() {
  const [statusTab, setStatusTab] = useState<PoStatus | 'all'>('all');
  const [supplierFilter, setSupplierFilter] = useState<string>('all');

  const filtered = useMemo(() => {
    return MOCK_PURCHASE_ORDERS.filter((p) => {
      if (statusTab !== 'all' && p.status !== statusTab) return false;
      if (supplierFilter !== 'all' && p.supplierId !== supplierFilter) return false;
      return true;
    });
  }, [statusTab, supplierFilter]);

  const counts: Record<string, number> = { all: MOCK_PURCHASE_ORDERS.length };
  for (const p of MOCK_PURCHASE_ORDERS) counts[p.status] = (counts[p.status] ?? 0) + 1;

  const openCount = MOCK_PURCHASE_ORDERS.filter((p) => ['sent', 'confirmed', 'partial'].includes(p.status)).length;
  const next7Days = new Date(Date.now() + 7 * 86400000);
  const expectedThisWeek = MOCK_PURCHASE_ORDERS.filter((p) => {
    const d = new Date(p.expectedAt);
    return d <= next7Days && ['sent', 'confirmed', 'partial'].includes(p.status);
  }).length;
  const totalOpen = MOCK_PURCHASE_ORDERS
    .filter((p) => ['sent', 'confirmed', 'partial'].includes(p.status))
    .reduce((s, p) => s + p.totalInclVat, 0);

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Inkoop</h1>
            <span className="count-badge">{MOCK_PURCHASE_ORDERS.length}</span>
          </div>
          <p className="page-subtitle">Purchase orders aan leveranciers — status, ontvangsten en levertermijnen.</p>
        </div>
        <button type="button" className="btn btn-primary">
          <Plus size={15} strokeWidth={2.2} />
          Nieuwe PO
        </button>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 16, marginBottom: 20 }}>
        <SimpleKpi icon={<FileText size={16} />} label="Open PO's" value={String(openCount)} accent="info" />
        <SimpleKpi icon={<Truck size={16} />} label="Verwacht deze week" value={String(expectedThisWeek)} accent="warning" />
        <SimpleKpi icon={<AlertCircle size={16} />} label="Openstaand bedrag" value={formatMoney(totalOpen, { decimals: false })} accent="accent" />
      </div>

      <div className="toolbar" style={{ marginBottom: 16 }}>
        <div className="segmented">
          {STATUS_TABS.map((t) => (
            <button key={t.value} type="button" data-active={statusTab === t.value} onClick={() => setStatusTab(t.value)}>
              {t.label}
              <span className="seg-count">{counts[t.value] ?? 0}</span>
            </button>
          ))}
        </div>
        <select value={supplierFilter} onChange={(e) => setSupplierFilter(e.target.value)} style={{ padding: '6px 10px' }}>
          <option value="all">Alle leveranciers</option>
          {MOCK_SUPPLIERS.map((s) => <option key={s.id} value={s.id}>{s.name}</option>)}
        </select>
      </div>

      {filtered.length === 0 ? (
        <div className="empty-state">
          <div className="empty-state-icon"><FileText size={22} /></div>
          <h2>Geen PO's gevonden</h2>
          <p>Pas je filters aan om resultaten te zien.</p>
        </div>
      ) : (
        <div className="table-wrap">
          <div style={{ overflowX: 'auto' }}>
            <table className="table">
              <thead>
                <tr>
                  <th>PO</th>
                  <th>Leverancier</th>
                  <th>Datum</th>
                  <th>Verwacht</th>
                  <th style={{ textAlign: 'right' }}>Items</th>
                  <th style={{ textAlign: 'right' }}>Totaal</th>
                  <th>Status</th>
                  <th>Voortgang</th>
                </tr>
              </thead>
              <tbody>
                {filtered.map((p) => {
                  const pct = p.orderedQty > 0 ? Math.round((p.receivedQty / p.orderedQty) * 100) : 0;
                  const fillClass = pct >= 100 ? 'high' : pct >= 50 ? 'medium' : 'low';
                  return (
                    <tr key={p.id}>
                      <td className="mono" style={{ fontWeight: 600, color: 'var(--theme-accent)' }}>{p.number}</td>
                      <td>{p.supplierName}</td>
                      <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDate(p.createdAt)}</td>
                      <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDate(p.expectedAt)}</td>
                      <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{p.itemsCount}</td>
                      <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(p.totalInclVat)}</td>
                      <td><span className={`badge ${STATUS_BADGES[p.status].klass}`}>{STATUS_BADGES[p.status].label}</span></td>
                      <td style={{ minWidth: 140 }}>
                        <div className="stock-bar">
                          <div className="stock-bar-track">
                            <div className={`stock-bar-fill ${fillClass}`} style={{ width: `${Math.min(pct, 100)}%` }} />
                          </div>
                          <div className="stock-bar-label">{p.receivedQty} / {p.orderedQty} ontvangen</div>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

function SimpleKpi({ icon, label, value, accent }: { icon: React.ReactNode; label: string; value: string; accent: 'info' | 'success' | 'warning' | 'accent' }) {
  const color = accent === 'info' ? 'var(--info)' : accent === 'success' ? 'var(--success)' : accent === 'warning' ? 'var(--warning)' : 'var(--theme-accent)';
  return (
    <div className="kpi-card">
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span className="kpi-label">{label}</span>
        <span style={{ color, display: 'inline-grid', placeItems: 'center' }}>{icon}</span>
      </div>
      <h2 className="kpi-value">{value}</h2>
    </div>
  );
}
