import { createFileRoute, Link } from '@tanstack/react-router';
import { useEffect, useState, type FormEvent } from 'react';
import {
  Plus, Settings as SettingsIcon, ExternalLink, Layers, RefreshCcw,
  AlertTriangle, PauseCircle, CheckCircle2,
} from 'lucide-react';
import { type ChannelSlug, type MockChannel } from '@/lib/mock-data-extended';
import { ChannelStatusPill } from '@/components/orders/Pills';
import { formatRelative, formatNumber } from '@/lib/format';
import { useChannels, channelActions } from '@/lib/mock-state';
import { Drawer } from '@/components/ui/Drawer';
import { FormField } from '@/components/ui/FormField';
import { toast } from '@/lib/toast';

export const Route = createFileRoute('/_app/channels')({
  component: ChannelsPage,
});

function ChannelsPage() {
  const channels = useChannels();
  const [config, setConfig] = useState<MockChannel | null>(null);
  const [syncing, setSyncing] = useState<ChannelSlug | null>(null);

  function syncNow(c: MockChannel) {
    setSyncing(c.slug);
    setTimeout(() => {
      channelActions.setLastSync(c.slug);
      const synced = c.productsEnabled + Math.floor(Math.random() * 5);
      toast.success(`${c.name}: ${synced} producten gesynced`);
      setSyncing(null);
    }, 900);
  }

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Verkoop-kanalen</h1>
            <span className="count-badge">{channels.length}</span>
          </div>
          <p className="page-subtitle">Eigen storefronts en marketplaces — sync-status, productaantallen en orders.</p>
        </div>
        <div style={{ display: 'flex', gap: 8 }}>
          <Link to="/channels/matrix" className="btn btn-secondary">
            <Layers size={14} /> Per-product matrix
          </Link>
          <button
            type="button"
            className="btn btn-primary"
            onClick={() => toast.info('Kanaal-toevoegen komt in Fase 3 (vereist adapter-implementatie)')}
          >
            <Plus size={15} strokeWidth={2.2} />
            Kanaal toevoegen
          </button>
        </div>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(380px, 1fr))', gap: 16 }}>
        {channels.map((c) => (
          <div key={c.slug} className="card" style={{ position: 'relative', overflow: 'hidden' }}>
            <div
              style={{
                position: 'absolute', inset: 0,
                background: `radial-gradient(circle at top right, ${c.accentColor}10, transparent 60%)`,
                pointerEvents: 'none',
              }}
            />
            <div className="card-header" style={{ alignItems: 'flex-start', position: 'relative' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
                <div
                  style={{
                    width: 46, height: 46, borderRadius: 11,
                    background: c.accentColor,
                    display: 'grid', placeItems: 'center',
                    color: '#fff', fontWeight: 800, fontSize: 20,
                    boxShadow: '0 4px 12px rgba(0,0,0,0.3)',
                    flexShrink: 0,
                  }}
                >
                  {c.logoLetter}
                </div>
                <div style={{ minWidth: 0 }}>
                  <h2 className="card-title" style={{ marginBottom: 3 }}>{c.name}</h2>
                  <div style={{ display: 'flex', gap: 6, alignItems: 'center', flexWrap: 'wrap' }}>
                    <span className="badge badge-neutral" style={{ fontSize: 10.5 }}>
                      {c.type === 'storefront' ? 'Eigen webshop' : c.type === 'marketplace' ? 'Marketplace' : 'Feed'}
                    </span>
                    <button
                      type="button"
                      onClick={() => {
                        channelActions.toggleActive(c.slug);
                        toast.success(`${c.name} ${c.status === 'paused' ? 'geactiveerd' : 'gepauzeerd'}`);
                      }}
                      style={{
                        background: 'transparent',
                        border: 'none',
                        padding: 0,
                        cursor: 'pointer',
                      }}
                      title="Klik om te (de)activeren"
                    >
                      <ChannelStatusPill status={c.status} />
                    </button>
                  </div>
                </div>
              </div>
              <StatusIcon status={c.status} />
            </div>

            {c.domain && (
              <div style={{
                display: 'flex', alignItems: 'center', gap: 6,
                fontSize: 12.5, color: 'var(--theme-muted)', marginBottom: 12,
                position: 'relative',
              }}>
                <ExternalLink size={12} />
                <span className="mono">{c.domain}</span>
              </div>
            )}

            <div style={{
              display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, marginBottom: 12, position: 'relative',
            }}>
              <Mini label="Producten live" value={formatNumber(c.productsEnabled)} />
              <Mini label="Niet actief" value={formatNumber(c.productsDisabled)} muted />
              <Mini label="Orders vandaag" value={formatNumber(c.ordersToday)} accent={c.ordersToday > 0} />
            </div>

            <div style={{
              fontSize: 12, lineHeight: 1.45, padding: '10px 12px',
              background: 'var(--surface-2)', borderRadius: 8,
              border: '1px solid var(--border-subtle)', color: 'var(--text-soft)',
              marginBottom: 12, position: 'relative',
            }}>
              <div style={{
                display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 4,
              }}>
                <span style={{ fontSize: 10.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em', fontWeight: 600 }}>
                  Laatst gesynced
                </span>
                <span style={{ fontSize: 11, color: 'var(--text-soft)' }}>
                  {formatRelative(c.lastSync)}
                </span>
              </div>
              {c.health}
            </div>

            <div style={{ display: 'flex', gap: 6, position: 'relative' }}>
              <button
                type="button"
                className="btn btn-secondary btn-sm"
                style={{ flex: 1, justifyContent: 'center' }}
                onClick={() => setConfig(c)}
              >
                <SettingsIcon size={13} /> Configureren
              </button>
              <button
                type="button"
                className="btn btn-secondary btn-sm"
                style={{ flex: 1, justifyContent: 'center' }}
                onClick={() => syncNow(c)}
                disabled={syncing === c.slug || c.status === 'paused'}
              >
                <RefreshCcw size={13} className={syncing === c.slug ? 'spin' : ''} />
                {syncing === c.slug ? 'Syncen…' : 'Nu syncen'}
              </button>
            </div>
          </div>
        ))}

        {/* Add new card */}
        <button
          type="button"
          className="card"
          onClick={() => toast.info('Kanaal-toevoegen komt in Fase 3')}
          style={{
            border: '1px dashed var(--border-default)',
            background: 'transparent',
            display: 'flex', flexDirection: 'column',
            alignItems: 'center', justifyContent: 'center',
            minHeight: 280, cursor: 'pointer', color: 'var(--theme-muted)',
            padding: 24,
          }}
        >
          <div style={{
            width: 48, height: 48, borderRadius: 14,
            background: 'var(--surface-3)', border: '1px solid var(--border-default)',
            display: 'grid', placeItems: 'center', marginBottom: 12,
            color: 'var(--theme-accent)',
          }}>
            <Plus size={20} strokeWidth={2.4} />
          </div>
          <div style={{ fontWeight: 600, color: 'var(--theme-text)', marginBottom: 4 }}>
            Voeg kanaal toe
          </div>
          <div style={{ fontSize: 12, textAlign: 'center', maxWidth: 240 }}>
            Connect Marktplaats, Etsy, Shopify of bouw eigen adapter.
          </div>
        </button>
      </div>

      <ChannelConfigDrawer channel={config} onClose={() => setConfig(null)} />

      {/* tiny inline keyframe for spinner */}
      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        .spin { animation: spin 0.9s linear infinite; }
      `}</style>
    </div>
  );
}

function ChannelConfigDrawer({
  channel,
  onClose,
}: {
  channel: MockChannel | null;
  onClose: () => void;
}) {
  const open = channel != null;
  const slug = channel?.slug;

  // Generic form-state per channel
  const [feedUrl, setFeedUrl] = useState('');
  const [refreshInterval, setRefreshInterval] = useState(60);
  const [targetCountry, setTargetCountry] = useState('NL');
  const [vatMode, setVatMode] = useState('inclusive');
  const [clientId, setClientId] = useState('');
  const [clientSecret, setClientSecret] = useState('');
  const [autoFulfill, setAutoFulfill] = useState(true);
  const [fbrFbb, setFbrFbb] = useState<'FBR' | 'FBB'>('FBR');
  const [refreshToken, setRefreshToken] = useState('');
  const [marketplaceId, setMarketplaceId] = useState('A1805IZSGTT6HS');
  const [vcsMode, setVcsMode] = useState(false);
  const [apiToken, setApiToken] = useState('');
  const [allowedOrigins, setAllowedOrigins] = useState('https://cremaenco.nl');
  const [webhookUrl, setWebhookUrl] = useState('');

  useEffect(() => {
    if (!open || !slug) return;
    const cfg = channelActions.getConfig(slug) ?? {};
    setFeedUrl((cfg.feedUrl as string) ?? `https://api.example.com/feeds/${slug}.xml`);
    setRefreshInterval((cfg.refreshInterval as number) ?? 60);
    setTargetCountry((cfg.targetCountry as string) ?? 'NL');
    setVatMode((cfg.vatMode as string) ?? 'inclusive');
    setClientId((cfg.clientId as string) ?? '');
    setClientSecret('');
    setAutoFulfill((cfg.autoFulfill as boolean) ?? true);
    setFbrFbb(((cfg.fbrFbb as string) ?? 'FBR') as 'FBR' | 'FBB');
    setRefreshToken('');
    setMarketplaceId((cfg.marketplaceId as string) ?? 'A1805IZSGTT6HS');
    setVcsMode((cfg.vcsMode as boolean) ?? false);
    setApiToken('');
    setAllowedOrigins((cfg.allowedOrigins as string) ?? `https://${channel?.domain ?? 'example.com'}`);
    setWebhookUrl((cfg.webhookUrl as string) ?? '');
  }, [open, slug]);

  function onSubmit(e: FormEvent) {
    e.preventDefault();
    if (!slug) return;
    const cfg: Record<string, unknown> = {};
    if (slug === 'gmc') {
      Object.assign(cfg, { feedUrl, refreshInterval, targetCountry, vatMode });
    } else if (slug === 'bol') {
      Object.assign(cfg, { clientId, autoFulfill, fbrFbb });
    } else if (slug === 'amazon-nl') {
      Object.assign(cfg, { marketplaceId, vcsMode });
    } else {
      Object.assign(cfg, { allowedOrigins, webhookUrl });
    }
    channelActions.saveConfig(slug, cfg);
    toast.success(`Configuratie ${channel?.name} opgeslagen`);
    onClose();
  }

  function regenerateToken() {
    const token = `sk_${Math.random().toString(36).slice(2, 18)}_${Math.random().toString(36).slice(2, 12)}`;
    setApiToken(token);
    toast.success('Nieuwe token gegenereerd — kopieer hem nu, hij wordt niet opnieuw getoond');
  }

  const fields = (() => {
    if (slug === 'gmc') {
      return (
        <>
          <FormField label="Feed-URL" hint="Endpoint waar Google de XML-feed ophaalt.">
            <input type="url" value={feedUrl} onChange={(e) => setFeedUrl(e.target.value)} />
          </FormField>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8 }}>
            <FormField label="Refresh-interval (min)">
              <input type="number" min={5} max={1440} value={refreshInterval} onChange={(e) => setRefreshInterval(Number(e.target.value))} />
            </FormField>
            <FormField label="Doelland">
              <select value={targetCountry} onChange={(e) => setTargetCountry(e.target.value)}>
                <option>NL</option><option>BE</option><option>DE</option><option>FR</option>
              </select>
            </FormField>
          </div>
          <FormField label="BTW-mode">
            <select value={vatMode} onChange={(e) => setVatMode(e.target.value)}>
              <option value="inclusive">Inclusive (default)</option>
              <option value="exclusive">Exclusive</option>
            </select>
          </FormField>
        </>
      );
    }
    if (slug === 'bol') {
      return (
        <>
          <FormField label="Client-ID" required>
            <input type="text" value={clientId} onChange={(e) => setClientId(e.target.value)} placeholder="bol-xxxxxxxx-xxxx" required />
          </FormField>
          <FormField label="Client-secret" hint="Wordt versleuteld opgeslagen.">
            <input type="password" value={clientSecret} onChange={(e) => setClientSecret(e.target.value)} placeholder="••••••••" />
          </FormField>
          <FormField label="Default fulfillment">
            <div className="segmented">
              <button type="button" data-active={fbrFbb === 'FBR'} onClick={() => setFbrFbb('FBR')}>FBR (eigen)</button>
              <button type="button" data-active={fbrFbb === 'FBB'} onClick={() => setFbrFbb('FBB')}>FBB (Bol)</button>
            </div>
          </FormField>
          <label style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 13, padding: '10px 12px', background: 'var(--surface-2)', borderRadius: 8 }}>
            <input type="checkbox" checked={autoFulfill} onChange={(e) => setAutoFulfill(e.target.checked)} style={{ width: 16, height: 16, padding: 0 }} />
            Auto-fulfill — pakbonnen automatisch genereren bij nieuwe orders
          </label>
        </>
      );
    }
    if (slug === 'amazon-nl') {
      return (
        <>
          <FormField label="Refresh-token (SP-API)" required hint="Verkrijgbaar via Seller Central → Apps & Services.">
            <input type="password" value={refreshToken} onChange={(e) => setRefreshToken(e.target.value)} placeholder="Atza|••••••••" />
          </FormField>
          <FormField label="Marketplace-ID">
            <input type="text" value={marketplaceId} onChange={(e) => setMarketplaceId(e.target.value)} />
          </FormField>
          <label style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 13, padding: '10px 12px', background: 'var(--surface-2)', borderRadius: 8 }}>
            <input type="checkbox" checked={vcsMode} onChange={(e) => setVcsMode(e.target.checked)} style={{ width: 16, height: 16, padding: 0 }} />
            VCS-mode — eigen BTW-berekening (vereist NL-BTW-nummer)
          </label>
        </>
      );
    }
    // storefront
    return (
      <>
        <FormField label="Storefront-API-token" hint="Wordt na regeneratie 1× getoond.">
          <div style={{ display: 'flex', gap: 6 }}>
            <input
              type="text"
              value={apiToken || (channel ? `sk_${channel.slug}_••••••••` : '')}
              readOnly
              className="mono"
              style={{ flex: 1, fontSize: 11.5 }}
            />
            <button type="button" className="btn btn-secondary btn-sm" onClick={regenerateToken}>Genereer</button>
          </div>
        </FormField>
        <FormField label="Allowed origins" hint="CORS — komma-gescheiden URLs.">
          <input type="text" value={allowedOrigins} onChange={(e) => setAllowedOrigins(e.target.value)} />
        </FormField>
        <FormField label="Webhook-URL (orders)" hint="POST krijgt order-payload bij elke nieuwe order.">
          <input type="url" value={webhookUrl} onChange={(e) => setWebhookUrl(e.target.value)} placeholder="https://example.com/hooks/order" />
        </FormField>
      </>
    );
  })();

  return (
    <Drawer
      open={open}
      onClose={onClose}
      title={channel?.name}
      subtitle={channel ? `Configuratie • ${channel.type}` : undefined}
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>Annuleer</button>
          <button type="submit" form="ch-config" className="btn btn-primary">Opslaan</button>
        </>
      }
    >
      <form id="ch-config" onSubmit={onSubmit}>
        {fields}
      </form>
    </Drawer>
  );
}

function Mini({ label, value, muted, accent }: { label: string; value: string; muted?: boolean; accent?: boolean }) {
  return (
    <div style={{
      padding: '8px 10px',
      background: 'var(--surface-2)',
      border: '1px solid var(--border-subtle)',
      borderRadius: 8,
    }}>
      <div style={{
        fontSize: 10, color: 'var(--theme-muted)', textTransform: 'uppercase',
        letterSpacing: '0.05em', fontWeight: 600,
      }}>{label}</div>
      <div style={{
        fontSize: 18, fontWeight: 700, marginTop: 2,
        color: accent ? 'var(--theme-accent)' : muted ? 'var(--theme-muted)' : 'var(--text-strong)',
        fontVariantNumeric: 'tabular-nums',
      }}>{value}</div>
    </div>
  );
}

function StatusIcon({ status }: { status: 'connected' | 'warning' | 'error' | 'paused' }) {
  if (status === 'connected') return <CheckCircle2 size={18} style={{ color: 'var(--success)' }} />;
  if (status === 'warning') return <AlertTriangle size={18} style={{ color: 'var(--warning)' }} />;
  if (status === 'error') return <AlertTriangle size={18} style={{ color: 'var(--danger)' }} />;
  return <PauseCircle size={18} style={{ color: 'var(--theme-muted)' }} />;
}
