import { createFileRoute, Link, notFound } from '@tanstack/react-router';
import {
  ChevronLeft, Printer, RefreshCcw, X, Mail, Truck, Package, CheckCheck, MapPin, User, FileText,
} from 'lucide-react';
import { getOrder, getOrderEvents } from '@/lib/mock-data-extended';
import { ChannelPill, OrderStatusPill, PaymentStatusPill } from '@/components/orders/Pills';
import { formatMoney, formatDateTime } from '@/lib/format';

export const Route = createFileRoute('/_app/orders/$id')({
  component: OrderDetailPage,
  loader: ({ params }) => {
    const order = getOrder(params.id);
    if (!order) throw notFound();
    return order;
  },
});

const FULFILLMENT_STEPS = [
  { key: 'allocated', label: 'Allocated', icon: Package },
  { key: 'picked', label: 'Picked', icon: CheckCheck },
  { key: 'packed', label: 'Packed', icon: Package },
  { key: 'shipped', label: 'Shipped', icon: Truck },
] as const;

function OrderDetailPage() {
  const order = Route.useLoaderData();
  const events = getOrderEvents(order);

  const stepIndex = (() => {
    if (order.status === 'cancelled') return -1;
    if (order.status === 'open') return 0;
    if (order.status === 'allocated') return 1;
    if (order.status === 'picked') return 2;
    if (order.status === 'shipped') return 4;
    if (order.status === 'delivered') return 4;
    return 0;
  })();

  return (
    <div>
      <div style={{ marginBottom: 8 }}>
        <Link to="/orders" className="btn btn-ghost btn-sm" style={{ paddingLeft: 6 }}>
          <ChevronLeft size={14} />
          Terug naar orders
        </Link>
      </div>
      <div className="page-header">
        <div>
          <div style={{ fontSize: 11.5, color: 'var(--text-faint)', letterSpacing: '0.04em', textTransform: 'uppercase' }}>
            Order
          </div>
          <div className="page-title-row">
            <h1 className="page-title mono" style={{ fontFamily: 'inherit' }}>{order.number}</h1>
            <OrderStatusPill status={order.status} />
            <PaymentStatusPill status={order.paymentStatus} />
            <ChannelPill slug={order.channel} />
          </div>
          <p className="page-subtitle">
            Geplaatst {formatDateTime(order.createdAt)} • {order.itemsCount} items • {formatMoney(order.total)}
          </p>
        </div>
        <div style={{ display: 'flex', gap: 8 }}>
          <button type="button" className="btn btn-secondary"><Printer size={14} /> Factuur</button>
          <button type="button" className="btn btn-secondary"><Mail size={14} /> Bevestiging</button>
          <button type="button" className="btn btn-primary"><Truck size={14} /> Verzendlabel</button>
        </div>
      </div>

      <div className="detail-grid">
        {/* Main column */}
        <div className="section-stack">
          {/* Items card */}
          <div className="card card-flush">
            <div style={{ padding: '16px 20px', borderBottom: '1px solid var(--border-default)' }}>
              <h2 className="card-title">Items ({order.lines.length})</h2>
            </div>
            <table className="table" style={{ borderRadius: 0 }}>
              <thead>
                <tr>
                  <th>Product</th>
                  <th style={{ textAlign: 'right' }}>Aantal</th>
                  <th style={{ textAlign: 'right' }}>Prijs</th>
                  <th style={{ textAlign: 'right' }}>Totaal</th>
                </tr>
              </thead>
              <tbody>
                {order.lines.map((l) => (
                  <tr key={l.id}>
                    <td>
                      <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
                        <div style={{
                          width: 40, height: 40, borderRadius: 6, overflow: 'hidden',
                          background: 'var(--surface-1)', border: '1px solid var(--border-subtle)',
                          flexShrink: 0,
                        }}>
                          {l.imageUrl ? (
                            <img src={l.imageUrl} alt={l.title} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                          ) : (
                            <div style={{ width: '100%', height: '100%', display: 'grid', placeItems: 'center', color: 'var(--text-faint)' }}>
                              <Package size={16} />
                            </div>
                          )}
                        </div>
                        <div>
                          <div style={{ fontWeight: 500 }}>{l.title}</div>
                          <div className="mono" style={{ color: 'var(--theme-muted)' }}>{l.variantSku} • BTW {l.vatRate}%</div>
                        </div>
                      </div>
                    </td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{l.qty}×</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{formatMoney(l.unitPrice)}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(l.lineTotal)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Fulfillment card */}
          <div className="card">
            <div className="card-header">
              <h2 className="card-title">Fulfillment</h2>
              {order.trackingNumber && (
                <span className="badge badge-info mono" style={{ fontSize: 11 }}>{order.trackingNumber}</span>
              )}
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: `repeat(${FULFILLMENT_STEPS.length}, 1fr)`, gap: 8, position: 'relative' }}>
              {FULFILLMENT_STEPS.map((step, i) => {
                const Icon = step.icon;
                const done = stepIndex >= i + 1;
                const active = stepIndex === i;
                return (
                  <div key={step.key} style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 6 }}>
                    <div style={{
                      width: 36, height: 36, borderRadius: '50%',
                      display: 'grid', placeItems: 'center',
                      background: done ? 'var(--theme-accent)' : 'var(--surface-3)',
                      color: done ? '#170f07' : 'var(--theme-muted)',
                      border: active ? '2px solid var(--theme-accent)' : '1px solid var(--border-default)',
                      transition: 'all 200ms',
                    }}>
                      <Icon size={16} strokeWidth={2.2} />
                    </div>
                    <div style={{ fontSize: 12, fontWeight: 500, color: done ? 'var(--theme-text)' : 'var(--theme-muted)' }}>
                      {step.label}
                    </div>
                  </div>
                );
              })}
            </div>
            <div style={{ marginTop: 16, paddingTop: 14, borderTop: '1px solid var(--border-subtle)', display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 8 }}>
              <span style={{ fontSize: 13, color: 'var(--theme-muted)' }}>
                Methode: <strong style={{ color: 'var(--theme-text)' }}>{order.shippingMethod}</strong>
              </span>
              <button type="button" className="btn btn-secondary btn-sm">
                <Printer size={13} /> Pak-bon
              </button>
            </div>
          </div>

          {/* Timeline card */}
          <div className="card">
            <div className="card-header">
              <h2 className="card-title">Tijdlijn</h2>
            </div>
            <div className="activity-feed">
              {events.map((e, i) => (
                <div key={i} className="activity-item">
                  <div className={`activity-icon ${
                    e.kind === 'paid' ? 'icon-product' :
                    e.kind === 'shipped' || e.kind === 'delivered' ? 'icon-stock' : 'icon-order'
                  }`}>
                    {e.kind === 'created' && <FileText size={14} />}
                    {e.kind === 'paid' && <CheckCheck size={14} />}
                    {e.kind === 'allocated' && <Package size={14} />}
                    {e.kind === 'picked' && <CheckCheck size={14} />}
                    {e.kind === 'shipped' && <Truck size={14} />}
                    {e.kind === 'delivered' && <CheckCheck size={14} />}
                    {e.kind === 'cancelled' && <X size={14} />}
                  </div>
                  <div className="activity-text">
                    <div><strong>{e.label}</strong></div>
                    <div className="activity-actor">{e.description}</div>
                  </div>
                  <div className="activity-time">{formatDateTime(e.at)}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Aside */}
        <div className="aside-stack">
          <div className="card">
            <div className="card-header"><h2 className="card-title">Klant</h2></div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              <div className="avatar" style={{ width: 36, height: 36 }}>
                <User size={16} />
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontWeight: 600 }}>{order.customerName}</div>
                <div className="mono" style={{ color: 'var(--theme-muted)' }}>{order.shippingAddress.country}</div>
              </div>
            </div>
            <div className="divider" />
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: 13 }}>
              <Link to="/customers" className="btn btn-ghost btn-sm" style={{ justifyContent: 'flex-start' }}>
                Bekijk klant-profiel →
              </Link>
            </div>
          </div>

          <div className="card">
            <div className="card-header">
              <h2 className="card-title"><MapPin size={14} style={{ display: 'inline', verticalAlign: -2 }} /> Adres</h2>
            </div>
            <div style={{ fontSize: 13, lineHeight: 1.55 }}>
              <div style={{ fontWeight: 600 }}>{order.shippingAddress.name}</div>
              <div className="muted">{order.shippingAddress.street}</div>
              <div className="muted">{order.shippingAddress.zip} {order.shippingAddress.city}</div>
              <div className="muted">{order.shippingAddress.country}</div>
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">Betaling</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 8, fontSize: 13 }}>
              <Row label="Subtotaal (excl. BTW)" value={formatMoney(order.subtotalExclVat)} />
              {order.vatBreakdown.map((v) => (
                <Row key={v.label} label={v.label} value={formatMoney(v.amount)} />
              ))}
              <Row label="Verzending" value={formatMoney(order.shippingAmount)} />
              {order.discountAmount > 0 && (
                <Row label="Korting" value={`− ${formatMoney(order.discountAmount)}`} accent="danger" />
              )}
              <div className="divider" style={{ margin: '4px 0' }} />
              <Row label="Totaal" value={formatMoney(order.total)} bold />
              <div style={{ marginTop: 8, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <PaymentStatusPill status={order.paymentStatus} />
                <span style={{ fontSize: 12, color: 'var(--theme-muted)' }}>{order.paymentMethod}</span>
              </div>
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">BTW</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: 13 }}>
              <Row label="Scheme" value={order.vatScheme} />
              <Row label="BTW-bedrag" value={formatMoney(order.vatAmount)} />
              {order.invoiceNumber && (
                <Row label="Factuur" value={order.invoiceNumber} mono />
              )}
            </div>
          </div>

          <div className="card">
            <div className="card-header"><h2 className="card-title">Acties</h2></div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
              <button type="button" className="btn btn-secondary btn-sm" style={{ justifyContent: 'flex-start' }}>
                <RefreshCcw size={13} /> Refund verwerken
              </button>
              <button type="button" className="btn btn-secondary btn-sm" style={{ justifyContent: 'flex-start' }}>
                <Mail size={13} /> Stuur bevestiging opnieuw
              </button>
              {order.status !== 'cancelled' && order.status !== 'delivered' && (
                <button type="button" className="btn btn-danger btn-sm" style={{ justifyContent: 'flex-start' }}>
                  <X size={13} /> Annuleer order
                </button>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

function Row({ label, value, bold = false, mono = false, accent }: {
  label: string; value: string; bold?: boolean; mono?: boolean; accent?: 'danger';
}) {
  return (
    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: 8 }}>
      <span style={{ color: 'var(--theme-muted)' }}>{label}</span>
      <span
        className={mono ? 'mono' : ''}
        style={{
          fontWeight: bold ? 700 : 500,
          fontSize: bold ? 14 : 13,
          color: accent === 'danger' ? 'var(--danger)' : 'var(--theme-text)',
          fontVariantNumeric: 'tabular-nums',
        }}
      >
        {value}
      </span>
    </div>
  );
}
