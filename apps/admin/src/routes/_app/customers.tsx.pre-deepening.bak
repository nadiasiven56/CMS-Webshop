import { createFileRoute, Link } from '@tanstack/react-router';
import { useEffect, useMemo, useState, type FormEvent } from 'react';
import { Search, Users, Globe, TrendingUp, Building2, Plus, Mail, Phone, Edit3 } from 'lucide-react';
import { type MockCustomer } from '@/lib/mock-data-extended';
import { formatMoney, formatDate, formatRelative, initials, countryFlag } from '@/lib/format';
import { useCustomers, customerActions, useOrders } from '@/lib/mock-state';
import { Drawer } from '@/components/ui/Drawer';
import { FormField } from '@/components/ui/FormField';
import { toast } from '@/lib/toast';

export const Route = createFileRoute('/_app/customers')({
  component: CustomersPage,
});

const TYPE_TABS = [
  { value: 'all', label: 'Alle' },
  { value: 'B2C', label: 'B2C' },
  { value: 'B2B', label: 'B2B' },
] as const;

function CustomersPage() {
  const customers = useCustomers();
  const orders = useOrders();

  const [searchInput, setSearchInput] = useState('');
  const [search, setSearch] = useState('');
  const [typeTab, setTypeTab] = useState<typeof TYPE_TABS[number]['value']>('all');
  const [country, setCountry] = useState<string>('all');
  const [activeCustomer, setActiveCustomer] = useState<MockCustomer | null>(null);
  const [createOpen, setCreateOpen] = useState(false);

  useEffect(() => {
    const t = setTimeout(() => setSearch(searchInput), 250);
    return () => clearTimeout(t);
  }, [searchInput]);

  const allCountries = useMemo(() => {
    return Array.from(new Set(customers.map((c) => c.country))).sort();
  }, [customers]);

  const filtered = useMemo(() => {
    const q = search.trim().toLowerCase();
    return customers.filter((c) => {
      if (typeTab !== 'all' && c.type !== typeTab) return false;
      if (country !== 'all' && c.country !== country) return false;
      if (q) {
        const hay = `${c.fullName} ${c.email} ${c.company ?? ''} ${c.city} ${c.vatNumber ?? ''}`.toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }, [customers, search, typeTab, country]);

  const counts = {
    all: customers.length,
    B2C: customers.filter((c) => c.type === 'B2C').length,
    B2B: customers.filter((c) => c.type === 'B2B').length,
  };
  const newThisMonth = customers.filter((c) => {
    const d = new Date(c.createdAt);
    const now = new Date();
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  }).length;
  const avgLtv = customers.length > 0 ? customers.reduce((s, c) => s + c.lifetimeValue, 0) / customers.length : 0;

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Klanten</h1>
            <span className="count-badge">{customers.length}</span>
          </div>
          <p className="page-subtitle">Overzicht van alle klanten — B2C en B2B over alle kanalen.</p>
        </div>
        <button type="button" className="btn btn-primary" onClick={() => setCreateOpen(true)}>
          <Plus size={15} strokeWidth={2.2} />
          Klant toevoegen
        </button>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 16, marginBottom: 20 }}>
        <SimpleKpi icon={<Users size={16} />} label="Total klanten" value={String(customers.length)} accent="info" />
        <SimpleKpi icon={<TrendingUp size={16} />} label="Nieuw deze maand" value={String(newThisMonth)} accent="success" />
        <SimpleKpi icon={<Globe size={16} />} label="Gemiddelde LTV" value={formatMoney(avgLtv, { decimals: false })} accent="accent" />
        <SimpleKpi icon={<Building2 size={16} />} label="B2B-aandeel" value={`${counts.all > 0 ? Math.round((counts.B2B / counts.all) * 100) : 0}%`} accent="warning" />
      </div>

      <div className="toolbar" style={{ marginBottom: 16 }}>
        <div className="search-input">
          <Search size={14} />
          <input
            placeholder="Zoek op naam, email, bedrijf of stad…"
            value={searchInput}
            onChange={(e) => setSearchInput(e.target.value)}
          />
        </div>
        <div className="segmented">
          {TYPE_TABS.map((t) => (
            <button
              key={t.value}
              type="button"
              data-active={typeTab === t.value}
              onClick={() => setTypeTab(t.value)}
            >
              {t.label}
              <span className="seg-count">{counts[t.value]}</span>
            </button>
          ))}
        </div>
        <select value={country} onChange={(e) => setCountry(e.target.value)} style={{ padding: '6px 10px' }}>
          <option value="all">Alle landen</option>
          {allCountries.map((c) => <option key={c} value={c}>{countryFlag(c)} {c}</option>)}
        </select>
      </div>

      {filtered.length === 0 ? (
        <div className="empty-state">
          <div className="empty-state-icon"><Users size={22} /></div>
          <h2>Geen klanten gevonden</h2>
          <p>Pas je zoekopdracht of filters aan.</p>
        </div>
      ) : (
        <div className="table-wrap">
          <div style={{ overflowX: 'auto' }}>
            <table className="table">
              <thead>
                <tr>
                  <th>Klant</th>
                  <th>Email</th>
                  <th>Type</th>
                  <th style={{ textAlign: 'right' }}>Orders</th>
                  <th style={{ textAlign: 'right' }}>LTV</th>
                  <th>Laatste order</th>
                </tr>
              </thead>
              <tbody>
                {filtered.map((c) => (
                  <tr
                    key={c.id}
                    onClick={() => setActiveCustomer(c)}
                    style={{ cursor: 'pointer' }}
                  >
                    <td>
                      <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
                        <div className="avatar" style={{ width: 30, height: 30, fontSize: 11 }}>
                          {initials(c.fullName)}
                        </div>
                        <div>
                          <div style={{ fontWeight: 500 }}>{c.fullName}</div>
                          {c.company && <div style={{ fontSize: 11.5, color: 'var(--theme-muted)' }}>{c.company}</div>}
                        </div>
                      </div>
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{c.email}</td>
                    <td>
                      {c.type === 'B2B' ? (
                        <div style={{ display: 'flex', flexDirection: 'column', gap: 3 }}>
                          <span className="badge badge-accent">B2B</span>
                          {c.vatNumber && <span className="mono" style={{ fontSize: 10.5, color: 'var(--theme-muted)' }}>{c.vatNumber}</span>}
                        </div>
                      ) : (
                        <span className="badge">B2C</span>
                      )}
                    </td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{c.ordersCount}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(c.lifetimeValue, { decimals: false })}</td>
                    <td>
                      <div style={{ fontSize: 12.5 }}>{formatDate(c.lastOrderAt)}</div>
                      <div style={{ fontSize: 11, color: 'var(--text-faint)' }}>{formatRelative(c.lastOrderAt)}</div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <CustomerDrawer
        customer={activeCustomer}
        onClose={() => setActiveCustomer(null)}
        recentOrders={
          activeCustomer
            ? orders.filter((o) => o.customerId === activeCustomer.id || o.customerName === activeCustomer.fullName).slice(0, 5)
            : []
        }
      />

      <CreateCustomerDrawer open={createOpen} onClose={() => setCreateOpen(false)} />
    </div>
  );
}

function CustomerDrawer({
  customer,
  onClose,
  recentOrders,
}: {
  customer: MockCustomer | null;
  onClose: () => void;
  recentOrders: Array<{ id: string; number: string; createdAt: string; total: number; status: string }>;
}) {
  return (
    <Drawer
      open={customer !== null}
      onClose={onClose}
      title={customer?.fullName}
      subtitle={customer?.company || customer?.email}
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>
            Sluit
          </button>
          <button
            type="button"
            className="btn btn-secondary"
            onClick={() => toast.info('Klant-bewerken komt in Fase 2')}
          >
            <Edit3 size={13} /> Bewerken
          </button>
        </>
      }
    >
      {customer && (
        <>
          <div style={{ display: 'flex', gap: 14, alignItems: 'center', marginBottom: 18 }}>
            <div className="avatar" style={{ width: 48, height: 48, fontSize: 14 }}>
              {initials(customer.fullName)}
            </div>
            <div style={{ minWidth: 0 }}>
              <div style={{ fontSize: 15, fontWeight: 600 }}>{customer.fullName}</div>
              <div style={{ fontSize: 12.5, color: 'var(--theme-muted)', display: 'flex', alignItems: 'center', gap: 6 }}>
                <Mail size={12} /> {customer.email}
              </div>
              {customer.phone && (
                <div style={{ fontSize: 12.5, color: 'var(--theme-muted)', display: 'flex', alignItems: 'center', gap: 6, marginTop: 2 }}>
                  <Phone size={12} /> {customer.phone}
                </div>
              )}
            </div>
            <div style={{ marginLeft: 'auto' }}>
              {customer.type === 'B2B' ? (
                <span className="badge badge-accent">B2B</span>
              ) : (
                <span className="badge">B2C</span>
              )}
            </div>
          </div>

          {customer.company && (
            <div className="card" style={{ padding: 14, marginBottom: 14 }}>
              <h3 style={{ margin: 0, fontSize: 12.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em', marginBottom: 6 }}>
                Bedrijf
              </h3>
              <div style={{ fontSize: 14, fontWeight: 600 }}>{customer.company}</div>
              {customer.vatNumber && (
                <div className="mono" style={{ fontSize: 11.5, color: 'var(--theme-muted)', marginTop: 2 }}>
                  BTW: {customer.vatNumber}
                </div>
              )}
            </div>
          )}

          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, marginBottom: 14 }}>
            <Stat label="Orders" value={String(customer.ordersCount)} />
            <Stat label="LTV" value={formatMoney(customer.lifetimeValue, { decimals: false })} />
            <Stat label="Laatst" value={formatRelative(customer.lastOrderAt)} small />
          </div>

          <h3 style={{ margin: '0 0 8px', fontSize: 12.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em' }}>
            Adres
          </h3>
          <div style={{ fontSize: 13, lineHeight: 1.55, marginBottom: 16, color: 'var(--text-soft)' }}>
            <div>{customer.street}</div>
            <div>{customer.zip} {customer.city}</div>
            <div>{countryFlag(customer.country)} {customer.country}</div>
          </div>

          <h3 style={{ margin: '0 0 8px', fontSize: 12.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em' }}>
            Recente orders
          </h3>
          {recentOrders.length === 0 ? (
            <div style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>Geen recente orders.</div>
          ) : (
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
              {recentOrders.map((o) => (
                <Link
                  key={o.id}
                  to="/orders/$id"
                  params={{ id: o.number }}
                  onClick={onClose}
                  style={{
                    display: 'flex',
                    justifyContent: 'space-between',
                    alignItems: 'center',
                    padding: '8px 12px',
                    background: 'var(--surface-2)',
                    border: '1px solid var(--border-subtle)',
                    borderRadius: 8,
                    color: 'inherit',
                    textDecoration: 'none',
                  }}
                >
                  <span className="mono" style={{ fontSize: 12, color: 'var(--theme-accent)', fontWeight: 600 }}>
                    {o.number}
                  </span>
                  <span style={{ fontSize: 12, color: 'var(--theme-muted)' }}>{formatDate(o.createdAt)}</span>
                  <span style={{ fontSize: 12.5, fontWeight: 600 }}>{formatMoney(o.total)}</span>
                </Link>
              ))}
            </div>
          )}
        </>
      )}
    </Drawer>
  );
}

function CreateCustomerDrawer({ open, onClose }: { open: boolean; onClose: () => void }) {
  const [type, setType] = useState<'B2C' | 'B2B'>('B2C');
  const [fullName, setFullName] = useState('');
  const [email, setEmail] = useState('');
  const [phone, setPhone] = useState('');
  const [company, setCompany] = useState('');
  const [vatNumber, setVatNumber] = useState('');
  const [street, setStreet] = useState('');
  const [zip, setZip] = useState('');
  const [city, setCity] = useState('');
  const [country, setCountry] = useState('NL');

  useEffect(() => {
    if (open) {
      setType('B2C');
      setFullName(''); setEmail(''); setPhone('');
      setCompany(''); setVatNumber('');
      setStreet(''); setZip(''); setCity(''); setCountry('NL');
    }
  }, [open]);

  function onSubmit(e: FormEvent) {
    e.preventDefault();
    if (!fullName || !email) {
      toast.error('Naam en e-mail zijn verplicht');
      return;
    }
    const parts = fullName.trim().split(/\s+/);
    const firstName = parts[0] ?? fullName;
    const lastName = parts.slice(1).join(' ') || '';
    const c: MockCustomer = {
      id: `cust-${Date.now()}`,
      type,
      firstName,
      lastName,
      fullName,
      email,
      phone: phone || '',
      company: type === 'B2B' ? company || undefined : undefined,
      vatNumber: type === 'B2B' ? vatNumber || undefined : undefined,
      street: street || 'Onbekend',
      zip: zip || '0000 AA',
      city: city || 'Onbekend',
      country,
      ordersCount: 0,
      lifetimeValue: 0,
      lastOrderAt: new Date().toISOString(),
      createdAt: new Date().toISOString(),
      marketingOptIn: false,
    };
    customerActions.add(c);
    toast.success(`Klant ${fullName} toegevoegd`);
    onClose();
  }

  return (
    <Drawer
      open={open}
      onClose={onClose}
      title="Klant toevoegen"
      subtitle="Maak een handmatig klant-record aan."
      footer={
        <>
          <button type="button" className="btn btn-ghost" onClick={onClose}>Annuleer</button>
          <button type="submit" form="cust-form" className="btn btn-primary">Aanmaken</button>
        </>
      }
    >
      <form id="cust-form" onSubmit={onSubmit}>
        <FormField label="Type">
          <div className="segmented">
            <button type="button" data-active={type === 'B2C'} onClick={() => setType('B2C')}>B2C</button>
            <button type="button" data-active={type === 'B2B'} onClick={() => setType('B2B')}>B2B</button>
          </div>
        </FormField>
        <FormField label="Volledige naam" required>
          <input type="text" value={fullName} onChange={(e) => setFullName(e.target.value)} required placeholder="Jan de Vries" />
        </FormField>
        <FormField label="E-mail" required>
          <input type="email" value={email} onChange={(e) => setEmail(e.target.value)} required placeholder="jan@voorbeeld.nl" />
        </FormField>
        <FormField label="Telefoon">
          <input type="tel" value={phone} onChange={(e) => setPhone(e.target.value)} placeholder="+31 6 12345678" />
        </FormField>
        {type === 'B2B' && (
          <>
            <FormField label="Bedrijf">
              <input type="text" value={company} onChange={(e) => setCompany(e.target.value)} placeholder="Acme BV" />
            </FormField>
            <FormField label="BTW-nummer">
              <input type="text" value={vatNumber} onChange={(e) => setVatNumber(e.target.value)} placeholder="NL123456789B01" />
            </FormField>
          </>
        )}
        <FormField label="Straat">
          <input type="text" value={street} onChange={(e) => setStreet(e.target.value)} />
        </FormField>
        <div style={{ display: 'grid', gridTemplateColumns: '120px 1fr 100px', gap: 8 }}>
          <FormField label="Postcode">
            <input type="text" value={zip} onChange={(e) => setZip(e.target.value)} />
          </FormField>
          <FormField label="Plaats">
            <input type="text" value={city} onChange={(e) => setCity(e.target.value)} />
          </FormField>
          <FormField label="Land">
            <select value={country} onChange={(e) => setCountry(e.target.value)}>
              <option>NL</option><option>BE</option><option>DE</option><option>FR</option>
              <option>IT</option><option>ES</option><option>GB</option>
            </select>
          </FormField>
        </div>
      </form>
    </Drawer>
  );
}

function Stat({ label, value, small }: { label: string; value: string; small?: boolean }) {
  return (
    <div style={{
      padding: '10px 12px',
      background: 'var(--surface-2)',
      border: '1px solid var(--border-subtle)',
      borderRadius: 8,
    }}>
      <div style={{ fontSize: 10.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em', fontWeight: 600 }}>{label}</div>
      <div style={{ fontSize: small ? 13 : 18, fontWeight: 700, color: 'var(--text-strong)', fontVariantNumeric: 'tabular-nums', marginTop: 2 }}>{value}</div>
    </div>
  );
}

function SimpleKpi({ icon, label, value, accent }: { icon: React.ReactNode; label: string; value: string; accent: 'info' | 'success' | 'warning' | 'accent' }) {
  const color = accent === 'info' ? 'var(--info)' : accent === 'success' ? 'var(--success)' : accent === 'warning' ? 'var(--warning)' : 'var(--theme-accent)';
  return (
    <div className="kpi-card">
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span className="kpi-label">{label}</span>
        <span style={{ color, display: 'inline-grid', placeItems: 'center' }}>{icon}</span>
      </div>
      <h2 className="kpi-value">{value}</h2>
    </div>
  );
}
