import { createFileRoute, Link } from '@tanstack/react-router';
import { useEffect, useMemo, useState } from 'react';
import {
  Search, Undo2, RefreshCcw, AlertCircle, Euro,
  CheckCircle2, X as XIcon, PackageCheck,
} from 'lucide-react';
import { type ReturnReason, type ReturnStatus, type MockReturn } from '@/lib/mock-data-extended';
import { formatMoney, formatDate, formatRelative } from '@/lib/format';
import { useReturns, returnActions } from '@/lib/mock-state';
import { Drawer } from '@/components/ui/Drawer';
import { ConfirmDialog } from '@/components/ui/ConfirmDialog';
import { toast } from '@/lib/toast';

export const Route = createFileRoute('/_app/returns')({
  component: ReturnsPage,
});

const STATUS_TABS: Array<{ value: ReturnStatus | 'all'; label: string }> = [
  { value: 'all', label: 'Alle' },
  { value: 'requested', label: 'Aangevraagd' },
  { value: 'approved', label: 'Goedgekeurd' },
  { value: 'received', label: 'Ontvangen' },
  { value: 'refunded', label: 'Terugbetaald' },
  { value: 'rejected', label: 'Afgewezen' },
];

const REASON_LABELS: Record<ReturnReason, { label: string; klass: string }> = {
  'niet-passend': { label: 'Niet passend', klass: 'badge-info' },
  'defect': { label: 'Defect', klass: 'badge-danger' },
  'verkeerd-product': { label: 'Verkeerd product', klass: 'badge-warning' },
  'overig': { label: 'Overig', klass: 'badge-neutral' },
};

const STATUS_LABELS: Record<ReturnStatus, { label: string; klass: string }> = {
  requested: { label: 'Aangevraagd', klass: 'badge-info' },
  approved: { label: 'Goedgekeurd', klass: 'badge-warning' },
  received: { label: 'Ontvangen', klass: 'badge-accent' },
  refunded: { label: 'Terugbetaald', klass: 'badge-success' },
  rejected: { label: 'Afgewezen', klass: 'badge-danger' },
};

function ReturnsPage() {
  const returns = useReturns();
  const [searchInput, setSearchInput] = useState('');
  const [search, setSearch] = useState('');
  const [statusTab, setStatusTab] = useState<ReturnStatus | 'all'>('all');
  const [reasonFilter, setReasonFilter] = useState<Set<ReturnReason>>(new Set());
  const [activeReturn, setActiveReturn] = useState<MockReturn | null>(null);
  const [confirmReject, setConfirmReject] = useState<MockReturn | null>(null);

  useEffect(() => {
    const t = setTimeout(() => setSearch(searchInput), 250);
    return () => clearTimeout(t);
  }, [searchInput]);

  const filtered = useMemo(() => {
    const q = search.trim().toLowerCase();
    return returns.filter((r) => {
      if (statusTab !== 'all' && r.status !== statusTab) return false;
      if (reasonFilter.size > 0 && !reasonFilter.has(r.reason)) return false;
      if (q) {
        const hay = `${r.rmaNumber} ${r.orderNumber} ${r.customerName}`.toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });
  }, [returns, search, statusTab, reasonFilter]);

  const counts: Record<string, number> = { all: returns.length };
  for (const r of returns) counts[r.status] = (counts[r.status] ?? 0) + 1;

  const openCount = returns.filter((r) => ['requested', 'approved', 'received'].includes(r.status)).length;
  const refundedThisMonth = returns.filter((r) => {
    if (r.status !== 'refunded' || !r.closedAt) return false;
    const d = new Date(r.closedAt);
    const now = new Date();
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  });
  const totalRefund = returns.reduce((s, r) => s + r.refundAmount, 0);
  const returnRate = returns.length > 0 ? (returns.length / 318) * 100 : 0;

  function toggleReason(r: ReturnReason) {
    setReasonFilter((prev) => {
      const n = new Set(prev);
      if (n.has(r)) n.delete(r);
      else n.add(r);
      return n;
    });
  }

  // Live-updated active return
  const liveActive = activeReturn ? returns.find((r) => r.id === activeReturn.id) ?? null : null;

  return (
    <div>
      <div className="page-header">
        <div>
          <div className="page-title-row">
            <h1 className="page-title">Retouren</h1>
            <span className="count-badge">{returns.length}</span>
          </div>
          <p className="page-subtitle">RMA-aanvragen, ontvangsten en refunds.</p>
        </div>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 16, marginBottom: 20 }}>
        <SimpleKpi icon={<AlertCircle size={16} />} label="Open retouren" value={String(openCount)} accent="warning" />
        <SimpleKpi icon={<RefreshCcw size={16} />} label="Verwerkt deze maand" value={String(refundedThisMonth.length)} accent="success" />
        <SimpleKpi icon={<Undo2 size={16} />} label="Retour-percentage" value={`${returnRate.toFixed(1)}%`} accent="info" />
        <SimpleKpi icon={<Euro size={16} />} label="Refund-totaal" value={formatMoney(totalRefund, { decimals: false })} accent="accent" />
      </div>

      <div className="toolbar" style={{ marginBottom: 12 }}>
        <div className="search-input">
          <Search size={14} />
          <input
            placeholder="Zoek op RMA, order-nr of klant…"
            value={searchInput}
            onChange={(e) => setSearchInput(e.target.value)}
          />
        </div>
        <div className="segmented">
          {STATUS_TABS.map((t) => (
            <button key={t.value} type="button" data-active={statusTab === t.value} onClick={() => setStatusTab(t.value)}>
              {t.label}
              <span className="seg-count">{counts[t.value] ?? 0}</span>
            </button>
          ))}
        </div>
      </div>

      <div className="toolbar" style={{ marginBottom: 16, gap: 6 }}>
        <span style={{ fontSize: 12, color: 'var(--theme-muted)', marginRight: 4 }}>Reden:</span>
        {(Object.entries(REASON_LABELS) as Array<[ReturnReason, { label: string; klass: string }]>).map(([k, v]) => (
          <button
            key={k}
            type="button"
            className="badge"
            onClick={() => toggleReason(k)}
            style={{
              cursor: 'pointer',
              border: reasonFilter.has(k) ? '1px solid var(--theme-accent-border)' : '1px solid var(--border-default)',
              background: reasonFilter.has(k) ? 'var(--theme-accent-subtle)' : 'var(--theme-card2)',
              color: reasonFilter.has(k) ? 'var(--theme-accent)' : 'var(--theme-muted)',
            }}
          >
            {v.label}
          </button>
        ))}
      </div>

      {filtered.length === 0 ? (
        <div className="empty-state">
          <div className="empty-state-icon"><Undo2 size={22} /></div>
          <h2>Geen retouren gevonden</h2>
          <p>Pas je zoekopdracht of filters aan.</p>
        </div>
      ) : (
        <div className="table-wrap">
          <div style={{ overflowX: 'auto' }}>
            <table className="table">
              <thead>
                <tr>
                  <th>RMA</th>
                  <th>Order</th>
                  <th>Klant</th>
                  <th style={{ textAlign: 'right' }}>Items</th>
                  <th>Reden</th>
                  <th>Status</th>
                  <th style={{ textAlign: 'right' }}>Refund</th>
                  <th>Aangemaakt</th>
                </tr>
              </thead>
              <tbody>
                {filtered.map((r) => (
                  <tr
                    key={r.id}
                    onClick={() => setActiveReturn(r)}
                    style={{ cursor: 'pointer' }}
                  >
                    <td className="mono" style={{ fontWeight: 600, color: 'var(--theme-accent)' }}>{r.rmaNumber}</td>
                    <td className="mono">{r.orderNumber}</td>
                    <td>{r.customerName}</td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{r.itemsCount}</td>
                    <td>
                      <span className={`badge ${REASON_LABELS[r.reason].klass}`}>{REASON_LABELS[r.reason].label}</span>
                      <div style={{ fontSize: 11, color: 'var(--theme-muted)', marginTop: 3 }}>{r.reasonDetail}</div>
                    </td>
                    <td><span className={`badge ${STATUS_LABELS[r.status].klass}`}>{STATUS_LABELS[r.status].label}</span></td>
                    <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>
                      {r.refundAmount > 0 ? formatMoney(r.refundAmount) : <span className="muted">—</span>}
                    </td>
                    <td>
                      <div style={{ fontSize: 12.5 }}>{formatDate(r.createdAt)}</div>
                      <div style={{ fontSize: 11, color: 'var(--text-faint)' }}>{formatRelative(r.createdAt)}</div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <ReturnDrawer
        rma={liveActive}
        onClose={() => setActiveReturn(null)}
        onReject={(r) => setConfirmReject(r)}
      />

      <ConfirmDialog
        open={confirmReject !== null}
        onClose={() => setConfirmReject(null)}
        onConfirm={() => {
          if (confirmReject) {
            returnActions.setStatus(confirmReject.id, 'rejected');
            returnActions.setRefundAmount(confirmReject.id, 0);
            toast.success(`RMA ${confirmReject.rmaNumber} afgewezen`);
          }
        }}
        title="Retour afwijzen?"
        message={`RMA ${confirmReject?.rmaNumber} wordt gemarkeerd als afgewezen. Klant krijgt geen refund.`}
        confirmLabel="Ja, afwijzen"
      />
    </div>
  );
}

function ReturnDrawer({
  rma,
  onClose,
  onReject,
}: {
  rma: MockReturn | null;
  onClose: () => void;
  onReject: (r: MockReturn) => void;
}) {
  return (
    <Drawer
      open={rma !== null}
      onClose={onClose}
      title={rma?.rmaNumber}
      subtitle={`Order ${rma?.orderNumber} • ${rma?.customerName}`}
      footer={
        rma && (
          <>
            <button type="button" className="btn btn-ghost" onClick={onClose}>Sluit</button>
            {rma.status === 'requested' && (
              <>
                <button
                  type="button"
                  className="btn btn-secondary"
                  onClick={() => onReject(rma)}
                >
                  <XIcon size={13} /> Afwijzen
                </button>
                <button
                  type="button"
                  className="btn btn-primary"
                  onClick={() => {
                    returnActions.setStatus(rma.id, 'approved');
                    toast.success(`RMA ${rma.rmaNumber} goedgekeurd`);
                  }}
                >
                  <CheckCircle2 size={13} /> Goedkeuren
                </button>
              </>
            )}
            {rma.status === 'approved' && (
              <button
                type="button"
                className="btn btn-primary"
                onClick={() => {
                  returnActions.setStatus(rma.id, 'received');
                  toast.success(`RMA ${rma.rmaNumber} gemarkeerd als ontvangen`);
                }}
              >
                <PackageCheck size={13} /> Markeer ontvangen
              </button>
            )}
            {rma.status === 'received' && (
              <button
                type="button"
                className="btn btn-primary"
                onClick={() => {
                  returnActions.setStatus(rma.id, 'refunded');
                  toast.success(`Refund van ${formatMoney(rma.refundAmount)} verwerkt voor ${rma.rmaNumber}`);
                }}
              >
                <Euro size={13} /> Refund {formatMoney(rma.refundAmount)}
              </button>
            )}
          </>
        )
      }
    >
      {rma && (
        <>
          <div style={{ display: 'flex', gap: 6, marginBottom: 14 }}>
            <span className={`badge ${STATUS_LABELS[rma.status].klass}`}>{STATUS_LABELS[rma.status].label}</span>
            <span className={`badge ${REASON_LABELS[rma.reason].klass}`}>{REASON_LABELS[rma.reason].label}</span>
          </div>

          <h3 style={{ fontSize: 12.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 6px' }}>
            Reden
          </h3>
          <div style={{ fontSize: 13.5, marginBottom: 14, color: 'var(--text-soft)' }}>{rma.reasonDetail}</div>

          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 8, marginBottom: 14 }}>
            <Stat label="Items" value={String(rma.itemsCount)} />
            <Stat label="Refund" value={rma.refundAmount > 0 ? formatMoney(rma.refundAmount, { decimals: false }) : '—'} />
            <Stat label="Aangemaakt" value={formatRelative(rma.createdAt)} small />
          </div>

          <h3 style={{ fontSize: 12.5, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.06em', margin: '0 0 6px' }}>
            Gerelateerde order
          </h3>
          <Link
            to="/orders/$id"
            params={{ id: rma.orderNumber }}
            onClick={onClose}
            style={{
              display: 'flex',
              justifyContent: 'space-between',
              padding: '10px 12px',
              background: 'var(--surface-2)',
              border: '1px solid var(--border-subtle)',
              borderRadius: 8,
              color: 'inherit',
              textDecoration: 'none',
              marginBottom: 16,
            }}
          >
            <span className="mono" style={{ color: 'var(--theme-accent)', fontWeight: 600 }}>{rma.orderNumber}</span>
            <span style={{ color: 'var(--theme-muted)', fontSize: 12 }}>Open order →</span>
          </Link>

          {rma.closedAt && (
            <div style={{ fontSize: 12, color: 'var(--theme-muted)' }}>
              Gesloten op {formatDate(rma.closedAt)}
            </div>
          )}
        </>
      )}
    </Drawer>
  );
}

function Stat({ label, value, small }: { label: string; value: string; small?: boolean }) {
  return (
    <div style={{
      padding: '8px 10px',
      background: 'var(--surface-2)',
      border: '1px solid var(--border-subtle)',
      borderRadius: 8,
    }}>
      <div style={{ fontSize: 10, color: 'var(--theme-muted)', textTransform: 'uppercase', letterSpacing: '0.05em', fontWeight: 600 }}>{label}</div>
      <div style={{ fontSize: small ? 12 : 16, fontWeight: 700, color: 'var(--text-strong)', fontVariantNumeric: 'tabular-nums', marginTop: 2 }}>{value}</div>
    </div>
  );
}

function SimpleKpi({ icon, label, value, accent }: { icon: React.ReactNode; label: string; value: string; accent: 'info' | 'success' | 'warning' | 'accent' }) {
  const color = accent === 'info' ? 'var(--info)' : accent === 'success' ? 'var(--success)' : accent === 'warning' ? 'var(--warning)' : 'var(--theme-accent)';
  return (
    <div className="kpi-card">
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span className="kpi-label">{label}</span>
        <span style={{ color, display: 'inline-grid', placeItems: 'center' }}>{icon}</span>
      </div>
      <h2 className="kpi-value">{value}</h2>
    </div>
  );
}
