import { createFileRoute } from '@tanstack/react-router';
import { Plus, KeyRound, Trash2, Copy } from 'lucide-react';
import { MOCK_API_TOKENS } from '@/lib/mock-data-extended';
import { formatRelative, formatDate } from '@/lib/format';
import { SettingsTabs } from './settings.users';

export const Route = createFileRoute('/_app/settings/tokens')({
  component: TokensPage,
});

const SCOPE_LABELS: Record<string, { label: string; klass: string }> = {
  storefront: { label: 'Storefront', klass: 'badge-info' },
  channel: { label: 'Channel', klass: 'badge-warning' },
  admin: { label: 'Admin', klass: 'badge-accent' },
  webhook: { label: 'Webhook', klass: 'badge-neutral' },
};

function TokensPage() {
  return (
    <div>
      <div className="page-header">
        <div>
          <h1 className="page-title">Settings — API-tokens</h1>
          <p className="page-subtitle">Tokens voor storefront-API, channel-koppelingen en admin-readonly toegang.</p>
        </div>
        <button type="button" className="btn btn-primary">
          <Plus size={15} strokeWidth={2.2} />
          Nieuwe token
        </button>
      </div>

      <SettingsTabs active="tokens" />

      <div
        style={{
          padding: '12px 16px', marginBottom: 16,
          background: 'var(--theme-accent-subtle)',
          border: '1px solid var(--theme-accent-border)',
          borderRadius: 10,
          fontSize: 12.5, color: 'var(--theme-text)',
          display: 'flex', alignItems: 'flex-start', gap: 10,
        }}
      >
        <KeyRound size={16} style={{ color: 'var(--theme-accent)', marginTop: 2 }} />
        <div>
          <strong>Tokens worden maar één keer getoond.</strong>{' '}
          Direct na aanmaken kopiëren — daarna alleen het prefix zichtbaar. Gebruik scopes om de bevoegdheid te beperken.
        </div>
      </div>

      <div className="table-wrap">
        <div style={{ overflowX: 'auto' }}>
          <table className="table">
            <thead>
              <tr>
                <th>Label</th>
                <th>Token (prefix)</th>
                <th>Scope</th>
                <th>Laatst gebruikt</th>
                <th>Aangemaakt</th>
                <th>Status</th>
                <th style={{ textAlign: 'right' }}>Acties</th>
              </tr>
            </thead>
            <tbody>
              {MOCK_API_TOKENS.map((t) => {
                const scope = SCOPE_LABELS[t.scope]!;
                return (
                  <tr key={t.id} style={{ opacity: t.active ? 1 : 0.6 }}>
                    <td style={{ fontWeight: 500 }}>{t.label}</td>
                    <td>
                      <span className="mono" style={{ fontSize: 11.5, color: 'var(--theme-muted)' }}>
                        {t.prefix}…<span style={{ color: 'var(--text-faint)' }}>(verborgen)</span>
                      </span>
                    </td>
                    <td>
                      <span className={`badge ${scope.klass}`}>{scope.label}</span>
                      {t.scopeDetail && (
                        <div style={{ fontSize: 10.5, color: 'var(--theme-muted)', marginTop: 2 }}>{t.scopeDetail}</div>
                      )}
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>
                      {t.lastUsedAt ? formatRelative(t.lastUsedAt) : <span className="muted">nooit</span>}
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDate(t.createdAt)}</td>
                    <td>
                      {t.active ? (
                        <span className="badge badge-success">Actief</span>
                      ) : (
                        <span className="badge badge-neutral">Ingetrokken</span>
                      )}
                    </td>
                    <td style={{ textAlign: 'right' }}>
                      <button type="button" className="btn btn-ghost btn-sm" title="Kopieer prefix">
                        <Copy size={13} />
                      </button>
                      <button type="button" className="btn btn-ghost btn-sm" title="Intrekken" style={{ color: 'var(--danger)' }}>
                        <Trash2 size={13} />
                      </button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}
