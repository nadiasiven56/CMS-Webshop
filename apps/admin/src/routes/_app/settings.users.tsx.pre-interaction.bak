import { createFileRoute, Link } from '@tanstack/react-router';
import { Plus, ShieldCheck, MailPlus } from 'lucide-react';
import { MOCK_ADMIN_USERS } from '@/lib/mock-data-extended';
import { formatRelative, formatDate, initials } from '@/lib/format';

export const Route = createFileRoute('/_app/settings/users')({
  component: UsersPage,
});

const ROLE_LABEL: Record<string, { label: string; klass: string }> = {
  admin: { label: 'Admin', klass: 'badge-accent' },
  staff: { label: 'Staff', klass: 'badge-info' },
  fulfillment: { label: 'Fulfillment', klass: 'badge-info' },
  finance: { label: 'Finance', klass: 'badge-warning' },
  readonly: { label: 'Read-only', klass: 'badge-neutral' },
};

function UsersPage() {
  return (
    <div>
      <div className="page-header">
        <div>
          <h1 className="page-title">Settings — Users</h1>
          <p className="page-subtitle">Admin-gebruikers van het CRM. API-tokens en webhooks staan in aparte pagina's.</p>
        </div>
        <button type="button" className="btn btn-primary">
          <Plus size={15} strokeWidth={2.2} />
          Gebruiker uitnodigen
        </button>
      </div>

      <SettingsTabs active="users" />

      <div className="table-wrap">
        <div style={{ overflowX: 'auto' }}>
          <table className="table">
            <thead>
              <tr>
                <th>Naam</th>
                <th>Email</th>
                <th>Rol</th>
                <th>2FA</th>
                <th>Laatste login</th>
                <th>Aangemaakt</th>
                <th>Status</th>
                <th style={{ width: 40 }}></th>
              </tr>
            </thead>
            <tbody>
              {MOCK_ADMIN_USERS.map((u) => {
                const role = ROLE_LABEL[u.role] ?? { label: u.role, klass: 'badge-neutral' };
                return (
                  <tr key={u.id}>
                    <td>
                      <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
                        <div className="avatar" style={{ width: 30, height: 30, fontSize: 11 }}>
                          {initials(u.name)}
                        </div>
                        <div style={{ fontWeight: 500 }}>{u.name}</div>
                      </div>
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{u.email}</td>
                    <td><span className={`badge ${role.klass}`}>{role.label}</span></td>
                    <td>
                      {u.twoFactor ? (
                        <span style={{ display: 'inline-flex', alignItems: 'center', gap: 4, fontSize: 12, color: 'var(--success)' }}>
                          <ShieldCheck size={12} /> Aan
                        </span>
                      ) : (
                        <span style={{ fontSize: 12, color: 'var(--theme-muted)' }}>—</span>
                      )}
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>
                      {u.lastLoginAt ? formatRelative(u.lastLoginAt) : <span className="muted">Nooit</span>}
                    </td>
                    <td style={{ fontSize: 12.5, color: 'var(--theme-muted)' }}>{formatDate(u.createdAt)}</td>
                    <td>
                      {u.active ? (
                        <span className="badge badge-success">Actief</span>
                      ) : (
                        <span className="badge badge-warning">
                          <MailPlus size={11} /> Uitnodiging
                        </span>
                      )}
                    </td>
                    <td><button type="button" className="btn btn-ghost btn-sm">⋯</button></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

export function SettingsTabs({ active }: { active: 'general' | 'users' | 'tokens' | 'webhooks' }) {
  return (
    <div className="segmented" style={{ marginBottom: 20 }}>
      <Link to="/settings" data-active={active === 'general'}>Algemeen</Link>
      <Link to="/settings/users" data-active={active === 'users'}>Users</Link>
      <Link to="/settings/tokens" data-active={active === 'tokens'}>API-tokens</Link>
      <Link to="/settings/webhooks" data-active={active === 'webhooks'}>Webhooks</Link>
    </div>
  );
}
