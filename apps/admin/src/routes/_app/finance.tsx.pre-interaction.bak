import { createFileRoute, Link } from '@tanstack/react-router';
import { useState } from 'react';
import { Download, BarChart3, Receipt, AlertCircle, CalendarRange, ExternalLink } from 'lucide-react';
import {
  MOCK_FINANCE_KPIS,
  MOCK_CHANNEL_REVENUE,
  MOCK_VAT_BREAKDOWN,
  MOCK_UPCOMING_DECLARATIONS,
} from '@/lib/mock-data-extended';
import { formatMoney, formatPct, formatDate } from '@/lib/format';

export const Route = createFileRoute('/_app/finance')({
  component: FinancePage,
});

const PERIODS = [
  { value: 'month', label: 'Mei 2026' },
  { value: 'q2', label: 'Q2 2026' },
  { value: 'year', label: 'Jaar 2026' },
  { value: 'custom', label: 'Aangepast' },
] as const;

function FinancePage() {
  const [period, setPeriod] = useState<typeof PERIODS[number]['value']>('q2');
  const k = MOCK_FINANCE_KPIS;

  return (
    <div>
      <div className="page-header">
        <div>
          <h1 className="page-title">Financieel</h1>
          <p className="page-subtitle">Omzet, marge, BTW en aangiftes per periode.</p>
        </div>
        <div style={{ display: 'flex', gap: 8 }}>
          <Link to="/accounting" className="btn btn-secondary">
            <Receipt size={14} /> Boekhouding
          </Link>
          <button type="button" className="btn btn-secondary">
            <Download size={14} /> Export
          </button>
        </div>
      </div>

      {/* Period picker */}
      <div className="toolbar" style={{ marginBottom: 16 }}>
        <span style={{ fontSize: 12, color: 'var(--theme-muted)', display: 'flex', alignItems: 'center', gap: 6 }}>
          <CalendarRange size={13} /> Periode:
        </span>
        <div className="segmented">
          {PERIODS.map((p) => (
            <button key={p.value} type="button" data-active={period === p.value} onClick={() => setPeriod(p.value)}>
              {p.label}
            </button>
          ))}
        </div>
        <span style={{ marginLeft: 'auto', fontSize: 12, color: 'var(--theme-muted)' }}>
          Toont: <strong style={{ color: 'var(--theme-text)' }}>{k.periodLabel}</strong>
        </span>
      </div>

      {/* KPI grid */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: 14, marginBottom: 24 }}>
        <KpiCard label="Omzet (excl. BTW)" value={formatMoney(k.revenueExclVat)} hint={`${k.ordersCount} orders`} />
        <KpiCard label="BTW totaal" value={formatMoney(k.vatTotal)} hint="te dragen + OSS" />
        <KpiCard label="Inkoopwaarde (COGS)" value={formatMoney(k.cogs)} hint="exclusief verzending" />
        <KpiCard label="Bruto-marge €" value={formatMoney(k.grossMargin)} hint="omzet − COGS" accent />
        <KpiCard label="Bruto-marge %" value={formatPct(k.grossMarginPct)} hint={`vorige Q: ${formatPct(0.398)}`} accent />
        <KpiCard label="Verzendkosten netto" value={formatMoney(k.shippingCost - k.shippingRevenue)} hint={`opbrengst ${formatMoney(k.shippingRevenue)}`} />
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(380px, 1fr))', gap: 16, marginBottom: 16 }}>
        {/* Per-channel revenue */}
        <div className="card card-flush">
          <div style={{ padding: '16px 20px', borderBottom: '1px solid var(--border-default)', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
            <h2 className="card-title"><BarChart3 size={14} style={{ display: 'inline', verticalAlign: -2 }} /> Omzet per kanaal</h2>
            <button type="button" className="btn btn-ghost btn-sm">Bekijken →</button>
          </div>
          <table className="table">
            <thead>
              <tr>
                <th>Kanaal</th>
                <th style={{ textAlign: 'right' }}>Orders</th>
                <th style={{ textAlign: 'right' }}>Omzet</th>
                <th style={{ textAlign: 'right' }}>Marge</th>
              </tr>
            </thead>
            <tbody>
              {MOCK_CHANNEL_REVENUE.map((c) => (
                <tr key={c.channel}>
                  <td>{c.channelName}</td>
                  <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{c.orderCount}</td>
                  <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(c.revenue, { decimals: false })}</td>
                  <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>
                    <span style={{
                      color: c.marginPct >= 0.4 ? 'var(--success)' : c.marginPct >= 0.3 ? 'var(--warning)' : 'var(--theme-muted)',
                    }}>
                      {c.marginPct > 0 ? formatPct(c.marginPct) : '—'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* VAT breakdown */}
        <div className="card card-flush">
          <div style={{ padding: '16px 20px', borderBottom: '1px solid var(--border-default)' }}>
            <h2 className="card-title">BTW-breakdown</h2>
            <p className="card-subtitle">Per scheme — basis en bedrag.</p>
          </div>
          <table className="table">
            <thead>
              <tr>
                <th>Scheme</th>
                <th style={{ textAlign: 'right' }}>Basis</th>
                <th style={{ textAlign: 'right' }}>BTW</th>
              </tr>
            </thead>
            <tbody>
              {MOCK_VAT_BREAKDOWN.map((v) => (
                <tr key={v.scheme}>
                  <td>
                    <div>{v.label}</div>
                    <div style={{ fontSize: 10.5, color: 'var(--theme-muted)' }}>
                      {v.scheme} {v.declarationDeadline && `• deadline ${formatDate(v.declarationDeadline)}`}
                    </div>
                  </td>
                  <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums' }}>{formatMoney(v.base, { decimals: false })}</td>
                  <td style={{ textAlign: 'right', fontVariantNumeric: 'tabular-nums', fontWeight: 600 }}>{formatMoney(v.amount)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Upcoming declarations */}
      <div className="card" style={{ marginBottom: 16 }}>
        <div className="card-header">
          <div>
            <h2 className="card-title"><AlertCircle size={14} style={{ display: 'inline', verticalAlign: -2, color: 'var(--warning)' }} /> Aankomende aangiftes</h2>
            <p className="card-subtitle">BTW-NL, OSS, ICP en IOSS.</p>
          </div>
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {MOCK_UPCOMING_DECLARATIONS.map((d) => {
            const overdue = new Date(d.deadline) < new Date() && d.status === 'open';
            const klass = d.status === 'submitted' ? 'badge-success' : overdue ? 'badge-danger' : 'badge-warning';
            const statusLabel = d.status === 'submitted' ? 'Ingediend' : overdue ? 'Te laat' : 'Open';
            return (
              <div
                key={d.id}
                style={{
                  display: 'flex', justifyContent: 'space-between', alignItems: 'center',
                  padding: '10px 12px',
                  background: 'var(--surface-2)',
                  border: '1px solid var(--border-subtle)',
                  borderRadius: 8,
                  gap: 12, flexWrap: 'wrap',
                }}
              >
                <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
                  <div style={{ fontWeight: 600 }}>{d.type} <span style={{ color: 'var(--theme-muted)', fontWeight: 400 }}>— {d.period}</span></div>
                  <div style={{ fontSize: 11.5, color: 'var(--theme-muted)' }}>Deadline: {formatDate(d.deadline)}</div>
                </div>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontSize: 13, fontVariantNumeric: 'tabular-nums', color: 'var(--text-soft)' }}>
                    {d.expectedAmount > 0 ? formatMoney(d.expectedAmount) : '—'}
                  </span>
                  <span className={`badge ${klass}`}>{statusLabel}</span>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {/* Export-buttons */}
      <div className="card">
        <div className="card-header">
          <h2 className="card-title">Exports & koppelingen</h2>
        </div>
        <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
          <button type="button" className="btn btn-secondary">
            <Download size={13} /> UBL-bestanden Q2
          </button>
          <button type="button" className="btn btn-secondary">
            <Download size={13} /> OSS-CSV Q2
          </button>
          <button type="button" className="btn btn-secondary">
            <Download size={13} /> ICP-CSV Q2
          </button>
          <button type="button" className="btn btn-secondary">
            <ExternalLink size={13} /> Push naar Moneybird
          </button>
        </div>
      </div>
    </div>
  );
}

function KpiCard({ label, value, hint, accent }: { label: string; value: string; hint?: string; accent?: boolean }) {
  return (
    <div className="kpi-card" style={accent ? { borderColor: 'var(--theme-accent-border)', background: 'linear-gradient(180deg, var(--theme-accent-subtle) 0%, var(--theme-card) 60%)' } : undefined}>
      <span className="kpi-label">{label}</span>
      <h2 className="kpi-value" style={{ fontSize: 22 }}>{value}</h2>
      {hint && <p className="kpi-hint">{hint}</p>}
    </div>
  );
}
